{{ 'thank-you-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign h_ff = 'inherit'
  if section.settings.heading_font_family == 'heading'
    assign h_ff = 'var(--font-heading-family)'
  elsif section.settings.heading_font_family == 'body'
    assign h_ff = 'var(--font-body-family)'
  endif

  assign b_ff = 'inherit'
  if section.settings.body_font_family == 'heading'
    assign b_ff = 'var(--font-heading-family)'
  elsif section.settings.body_font_family == 'body'
    assign b_ff = 'var(--font-body-family)'
  endif
-%}

<section
  id="ThankYouCards-{{ section.id }}"
  class="ty-cards"
  style="
    --ty-cards-max: {{ section.settings.max_width }}px;
    --ty-cards-pt: {{ section.settings.padding_top }}px;
    --ty-cards-pb: {{ section.settings.padding_bottom }}px;
    --ty-cards-pt-m: {{ section.settings.padding_top_mobile }}px;
    --ty-cards-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --ty-cards-gap: {{ section.settings.grid_gap }}px;
    --ty-cards-card-pad: {{ section.settings.card_padding }}px;
    --ty-cards-heading-ff: {{ h_ff }};
    --ty-cards-body-ff: {{ b_ff }};
    --ty-cards-title-fs: {{ section.settings.card_title_size }}px;
    --ty-cards-title-fw: {{ section.settings.card_title_weight }};
    --ty-cards-title-style: {{ section.settings.card_title_style }};
    --ty-cards-body-fs: {{ section.settings.card_body_size }}px;
    --ty-cards-body-fw: {{ section.settings.card_body_weight }};
    --ty-cards-body-style: {{ section.settings.card_body_style }};
    --ty-cards-btn-fs: {{ section.settings.card_btn_size }}px;
    --ty-cards-btn-fw: {{ section.settings.card_btn_weight }};
  "
>
  <div class="ty-cards__inner">
    <div class="ty-cards__grid">
      <div
        class="ty-cards__card"
        style="background: {{ section.settings.card1_bg }};"
      >
        {% if section.settings.card1_title != blank %}
          <h3 class="ty-cards__card-title">{{ section.settings.card1_title }}</h3>
        {% endif %}
        {% if section.settings.card1_body != blank %}
          <div class="ty-cards__card-body rte">
            {{ section.settings.card1_body }}
          </div>
        {% endif %}
        {% if section.settings.card1_btn_label != blank and section.settings.card1_btn_url != blank %}
          <a
            href="{{ section.settings.card1_btn_url }}"
            class="ty-cards__btn"
            style="--ty-cards-btn-fg: {{ section.settings.card1_bg }};"
          >
            {{ section.settings.card1_btn_label }}
          </a>
        {% endif %}
      </div>

      <div
        class="ty-cards__card"
        style="background: {{ section.settings.card2_bg }};"
      >
        {% if section.settings.card2_title != blank %}
          <h3 class="ty-cards__card-title">{{ section.settings.card2_title }}</h3>
        {% endif %}
        {% if section.settings.card2_body != blank %}
          <div class="ty-cards__card-body rte">
            {{ section.settings.card2_body }}
          </div>
        {% endif %}
        {% if section.settings.card2_btn_label != blank and section.settings.card2_btn_url != blank %}
          <a
            href="{{ section.settings.card2_btn_url }}"
            class="ty-cards__btn"
            style="--ty-cards-btn-fg: {{ section.settings.card2_bg }};"
          >
            {{ section.settings.card2_btn_label }}
          </a>
        {% endif %}
      </div>

      <div
        class="ty-cards__card ty-cards__card--wide"
        style="background: {{ section.settings.card3_bg }};"
      >
        {% if section.settings.card3_title != blank %}
          <h3 class="ty-cards__card-title">{{ section.settings.card3_title }}</h3>
        {% endif %}
        {% if section.settings.card3_body != blank %}
          <div class="ty-cards__card-body rte">
            {{ section.settings.card3_body }}
          </div>
        {% endif %}
        {% if section.settings.card3_btn_label != blank and section.settings.card3_btn_url != blank %}
          <a
            href="{{ section.settings.card3_btn_url }}"
            class="ty-cards__btn"
            style="--ty-cards-btn-fg: {{ section.settings.card3_bg }};"
          >
            {{ section.settings.card3_btn_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Thank you cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Top left card"
    },
    {
      "type": "text",
      "id": "card1_title",
      "label": "Title",
      "default": "Stay Connected with Kefey"
    },
    {
      "type": "richtext",
      "id": "card1_body",
      "label": "Text",
      "default": "<p>Follow us for joyful tips, colorful moments &amp; surprises!</p>"
    },
    {
      "type": "text",
      "id": "card1_btn_label",
      "label": "Button label",
      "default": "FOLLOW US"
    },
    {
      "type": "url",
      "id": "card1_btn_url",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "card1_bg",
      "label": "Background",
      "default": "#4DB6AC"
    },
    {
      "type": "header",
      "content": "Top right card"
    },
    {
      "type": "text",
      "id": "card2_title",
      "label": "Title",
      "default": "Join the Joy Club"
    },
    {
      "type": "richtext",
      "id": "card2_body",
      "label": "Text",
      "default": "<p>Want more joy in your inbox? Subscribe now &amp; get our Joyful Drinks e-Book FREE!</p>"
    },
    {
      "type": "text",
      "id": "card2_btn_label",
      "label": "Button label",
      "default": "SUBSCRIBE NOW"
    },
    {
      "type": "url",
      "id": "card2_btn_url",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "card2_bg",
      "label": "Background",
      "default": "#4DB6AC"
    },
    {
      "type": "header",
      "content": "Full-width card"
    },
    {
      "type": "text",
      "id": "card3_title",
      "label": "Title",
      "default": "A Little Extra Joy"
    },
    {
      "type": "richtext",
      "id": "card3_body",
      "label": "Text",
      "default": "<p>Did you know? Our EcoTube is reusable! Turn it into a pen holder, mini vase, or even a smile bank.</p>"
    },
    {
      "type": "text",
      "id": "card3_btn_label",
      "label": "Button label (optional)"
    },
    {
      "type": "url",
      "id": "card3_btn_url",
      "label": "Button link (optional)"
    },
    {
      "type": "color",
      "id": "card3_bg",
      "label": "Background",
      "default": "#EF6C4D"
    },
    {
      "type": "header",
      "content": "Typography — card titles"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Font family",
      "default": "heading",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Size (px)",
      "min": 16,
      "max": 32,
      "step": 1,
      "default": 20
    },
    {
      "type": "select",
      "id": "card_title_weight",
      "label": "Weight",
      "default": "700",
      "options": [
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "select",
      "id": "card_title_style",
      "label": "Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "header",
      "content": "Typography — card body"
    },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Font family",
      "default": "body",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "range",
      "id": "card_body_size",
      "label": "Size (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "select",
      "id": "card_body_weight",
      "label": "Weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" }
      ]
    },
    {
      "type": "select",
      "id": "card_body_style",
      "label": "Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "header",
      "content": "Typography — card buttons"
    },
    {
      "type": "range",
      "id": "card_btn_size",
      "label": "Button text size (px)",
      "min": 11,
      "max": 16,
      "step": 1,
      "default": 13
    },
    {
      "type": "select",
      "id": "card_btn_weight",
      "label": "Button weight",
      "default": "700",
      "options": [
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 900,
      "max": 1400,
      "step": 10,
      "default": 1100
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards (px)",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card inner padding (px)",
      "min": 16,
      "max": 48,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Thank you cards"
    }
  ]
}
{% endschema %}
