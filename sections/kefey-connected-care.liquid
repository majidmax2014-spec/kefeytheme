{{ 'kefey-connected-care.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign kcc_h_ff = 'inherit'
  if section.settings.heading_font_family == 'heading'
    assign kcc_h_ff = 'var(--font-heading-family)'
  elsif section.settings.heading_font_family == 'body'
    assign kcc_h_ff = 'var(--font-body-family)'
  endif

  assign kcc_intro_ff = 'inherit'
  if section.settings.intro_font_family == 'heading'
    assign kcc_intro_ff = 'var(--font-heading-family)'
  elsif section.settings.intro_font_family == 'body'
    assign kcc_intro_ff = 'var(--font-body-family)'
  endif

  assign kcc_bot_ff = 'inherit'
  if section.settings.bottom_font_family == 'heading'
    assign kcc_bot_ff = 'var(--font-heading-family)'
  elsif section.settings.bottom_font_family == 'body'
    assign kcc_bot_ff = 'var(--font-body-family)'
  endif

  assign bar_h_m_em = section.settings.bar_height_mobile_frac | times: 0.01
  assign bar_pad_em = section.settings.bar_extend | times: 0.01
  assign bar_b_m_em = section.settings.bar_offset_bottom_mobile | times: 0.01
-%}

<section
  id="KefeyConnectedCare-{{ section.id }}"
  class="kcc"
  style="
    --kcc-bg: {{ section.settings.section_background }};
    --kcc-max: {{ section.settings.content_max_width }}px;
    --kcc-pt: {{ section.settings.padding_top }}px;
    --kcc-pb: {{ section.settings.padding_bottom }}px;
    --kcc-px: {{ section.settings.padding_horizontal }}px;
    --kcc-pt-m: {{ section.settings.padding_top_mobile }}px;
    --kcc-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --kcc-px-m: {{ section.settings.padding_horizontal_mobile }}px;
    --kcc-gap-h-intro: {{ section.settings.gap_heading_intro }}px;
    --kcc-gap-h-intro-m: {{ section.settings.gap_heading_intro_mobile }}px;
    --kcc-gap-intro-img: {{ section.settings.gap_intro_image }}px;
    --kcc-gap-intro-img-m: {{ section.settings.gap_intro_image_mobile }}px;
    --kcc-gap-img-bottom: {{ section.settings.gap_image_bottom }}px;
    --kcc-gap-img-bottom-m: {{ section.settings.gap_image_bottom_mobile }}px;
    --kcc-h-ff: {{ kcc_h_ff }};
    --kcc-h-fw: {{ section.settings.heading_font_weight }};
    --kcc-h-fs: {{ section.settings.heading_font_size }}px;
    --kcc-h-fs-m: {{ section.settings.heading_font_size_mobile }}px;
    --kcc-h-lh: {{ section.settings.heading_line_height | times: 0.01 }};
    --kcc-h-lh-m: {{ section.settings.heading_line_height_mobile | times: 0.01 }};
    --kcc-h-track: {{ section.settings.heading_letter_spacing | times: 0.001 }}em;
    --kcc-h-color: {{ section.settings.heading_color }};
    --kcc-bar-bg: {{ section.settings.bar_color }};
    --kcc-bar-radius: {{ section.settings.bar_border_radius }}px;
    --kcc-bar-pad: {{ bar_pad_em }}em;
    --kcc-bar-h-d: {{ section.settings.bar_height_desktop }}px;
    --kcc-bar-b-d: {{ section.settings.bar_offset_bottom_desktop }}px;
    --kcc-bar-h-m: {{ bar_h_m_em }}em;
    --kcc-bar-h-m-min: {{ section.settings.bar_height_mobile_min }}px;
    --kcc-bar-h-m-max: {{ section.settings.bar_height_mobile_max }}px;
    --kcc-bar-b-m: {{ bar_b_m_em }}em;
    --kcc-intro-ff: {{ kcc_intro_ff }};
    --kcc-intro-fw: {{ section.settings.intro_font_weight }};
    --kcc-intro-fs: {{ section.settings.intro_font_size }}px;
    --kcc-intro-fs-m: {{ section.settings.intro_font_size_mobile }}px;
    --kcc-intro-lh: {{ section.settings.intro_line_height | times: 0.01 }};
    --kcc-intro-lh-m: {{ section.settings.intro_line_height_mobile | times: 0.01 }};
    --kcc-intro-color: {{ section.settings.intro_color }};
    --kcc-img-max: {{ section.settings.image_max_width }}%;
    --kcc-img-max-m: {{ section.settings.image_max_width_mobile }}%;
    --kcc-img-radius: {{ section.settings.image_border_radius }}px;
    --kcc-bot-ff: {{ kcc_bot_ff }};
    --kcc-bot-fw: {{ section.settings.bottom_font_weight }};
    --kcc-bot-fs: {{ section.settings.bottom_font_size }}px;
    --kcc-bot-fs-m: {{ section.settings.bottom_font_size_mobile }}px;
    --kcc-bot-lh: {{ section.settings.bottom_line_height | times: 0.01 }};
    --kcc-bot-lh-m: {{ section.settings.bottom_line_height_mobile | times: 0.01 }};
    --kcc-bot-color: {{ section.settings.bottom_color }};
  "
>
  <div class="kcc__inner">
    {% if section.settings.heading != blank %}
      <div class="kcc__title-wrap">
        <h2 class="kcc__title">
          <span class="kcc__title-text">{{ section.settings.heading }}</span>
          <span class="kcc__title-bar" aria-hidden="true"></span>
        </h2>
      </div>
    {% endif %}

    {% if section.settings.intro_text != blank %}
      <div class="kcc__intro rte">{{ section.settings.intro_text }}</div>
    {% endif %}

    {% if section.settings.image != blank %}
      {% capture kcc_single_img_sizes %}(max-width: 749px) 100vw, min(90vw, {{ section.settings.content_max_width }}px){% endcapture %}
      <div class="kcc__media">
        {% if section.settings.image_mobile != blank %}
          <picture>
            <source
              media="(max-width: 749px)"
              srcset="
                {{ section.settings.image_mobile | image_url: width: 550 }} 550w,
                {{ section.settings.image_mobile | image_url: width: 750 }} 750w,
                {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w
              "
              sizes="100vw"
            >
            {{
              section.settings.image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                widths: '550, 750, 1100, 1400, 1600',
                sizes: '(max-width: 749px) 100vw, 90vw',
                alt: section.settings.image.alt
            }}
          </picture>
        {% else %}
          {{
            section.settings.image
            | image_url: width: 1600
            | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 1100, 1400, 1600',
              sizes: kcc_single_img_sizes,
              alt: section.settings.image.alt
          }}
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.bottom_text != blank %}
      <div class="kcc__bottom rte">{{ section.settings.bottom_text }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Kefey connected care",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600,
      "max": 1200,
      "step": 10,
      "default": 960
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal (desktop)",
      "min": 12,
      "max": 64,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Padding horizontal (mobile)",
      "min": 12,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "A <strong>Connected Kind of Care</strong>"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Font",
      "default": "heading",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Weight",
      "default": "700",
      "options": [
        { "value": "inherit", "label": "inherit" },
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Size (desktop)",
      "min": 24,
      "max": 56,
      "step": 1,
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Size (mobile)",
      "min": 18,
      "max": 40,
      "step": 1,
      "default": 26
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Line height (%)",
      "min": 100,
      "max": 140,
      "step": 2,
      "default": 112
    },
    {
      "type": "range",
      "id": "heading_line_height_mobile",
      "label": "Line height mobile (%)",
      "min": 100,
      "max": 140,
      "step": 2,
      "default": 115
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Letter spacing",
      "min": -50,
      "max": 200,
      "step": 5,
      "default": 0
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Yellow bar (highlighter)"
    },
    {
      "type": "color",
      "id": "bar_color",
      "label": "Bar color",
      "default": "#ffd333"
    },
    {
      "type": "range",
      "id": "bar_height_desktop",
      "label": "Bar height (desktop)",
      "min": 6,
      "max": 32,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "bar_offset_bottom_desktop",
      "label": "Bar vertical offset (desktop)",
      "min": -16,
      "max": 16,
      "step": 1,
      "default": -4
    },
    {
      "type": "range",
      "id": "bar_extend",
      "label": "Bar extend past text (×0.01 em)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "bar_border_radius",
      "label": "Bar corner radius",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "bar_height_mobile_frac",
      "label": "Bar height mobile (em × 100)",
      "min": 28,
      "max": 52,
      "step": 1,
      "default": 42
    },
    {
      "type": "range",
      "id": "bar_height_mobile_min",
      "label": "Bar height mobile min (px)",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "bar_height_mobile_max",
      "label": "Bar height mobile max (px)",
      "min": 16,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "bar_offset_bottom_mobile",
      "label": "Bar offset mobile (×0.01 em)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Intro text"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Text",
      "default": "<p>For Kefey\u00ae, doing good is not only about where we give, but also about how we create.</p>"
    },
    {
      "type": "select",
      "id": "intro_font_family",
      "label": "Font",
      "default": "body",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "intro_font_weight",
      "label": "Weight",
      "default": "400",
      "options": [
        { "value": "inherit", "label": "inherit" },
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" }
      ]
    },
    {
      "type": "range",
      "id": "intro_font_size",
      "label": "Size (desktop)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "intro_font_size_mobile",
      "label": "Size (mobile)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "intro_line_height",
      "label": "Line height (%)",
      "min": 120,
      "max": 200,
      "step": 5,
      "default": 145
    },
    {
      "type": "range",
      "id": "intro_line_height_mobile",
      "label": "Line height mobile (%)",
      "min": 120,
      "max": 200,
      "step": 5,
      "default": 145
    },
    {
      "type": "color",
      "id": "intro_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Uses desktop image if empty."
    },
    {
      "type": "range",
      "id": "image_max_width",
      "label": "Max width (desktop %)",
      "min": 60,
      "max": 100,
      "step": 1,
      "default": 100
    },
    {
      "type": "range",
      "id": "image_max_width_mobile",
      "label": "Max width (mobile %)",
      "min": 85,
      "max": 100,
      "step": 1,
      "default": 100
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "Closing text"
    },
    {
      "type": "richtext",
      "id": "bottom_text",
      "label": "Text",
      "default": "<p>From paper-based tubes to reusable boxes, our choices are designed to borrow from nature with care, and give back with intention.</p>"
    },
    {
      "type": "select",
      "id": "bottom_font_family",
      "label": "Font",
      "default": "body",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "bottom_font_weight",
      "label": "Weight",
      "default": "400",
      "options": [
        { "value": "inherit", "label": "inherit" },
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" }
      ]
    },
    {
      "type": "range",
      "id": "bottom_font_size",
      "label": "Size (desktop)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "bottom_font_size_mobile",
      "label": "Size (mobile)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "bottom_line_height",
      "label": "Line height (%)",
      "min": 120,
      "max": 200,
      "step": 5,
      "default": 145
    },
    {
      "type": "range",
      "id": "bottom_line_height_mobile",
      "label": "Line height mobile (%)",
      "min": 120,
      "max": 200,
      "step": 5,
      "default": 145
    },
    {
      "type": "color",
      "id": "bottom_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "gap_heading_intro",
      "label": "Below heading → intro",
      "min": 0,
      "max": 64,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "gap_heading_intro_mobile",
      "label": "Below heading → intro (mobile)",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_intro_image",
      "label": "Below intro → image",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_intro_image_mobile",
      "label": "Below intro → image (mobile)",
      "min": 0,
      "max": 64,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "gap_image_bottom",
      "label": "Below image → closing text",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_image_bottom_mobile",
      "label": "Below image → closing text (mobile)",
      "min": 0,
      "max": 64,
      "step": 2,
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Kefey connected care"
    }
  ]
}
{% endschema %}
