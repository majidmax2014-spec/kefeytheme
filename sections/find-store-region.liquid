{{ 'kefey-find-store.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign t_ff = 'inherit'
  if section.settings.title_font_family == 'heading'
    assign t_ff = 'var(--font-heading-family)'
  elsif section.settings.title_font_family == 'body'
    assign t_ff = 'var(--font-body-family)'
  endif

  assign b_ff = 'inherit'
  if section.settings.body_font_family == 'heading'
    assign b_ff = 'var(--font-heading-family)'
  elsif section.settings.body_font_family == 'body'
    assign b_ff = 'var(--font-body-family)'
  endif
-%}

<section
  id="FindStoreRegion-{{ section.id }}"
  class="fs-region"
  style="
    --fs-region-max: {{ section.settings.max_width }}px;
    --fs-region-pt: {{ section.settings.padding_top }}px;
    --fs-region-pb: {{ section.settings.padding_bottom }}px;
    --fs-region-title-ff: {{ t_ff }};
    --fs-region-title-fs: {{ section.settings.title_size }}px;
    --fs-region-body-ff: {{ b_ff }};
  "
>
  <div class="fs-region__inner">
    {% if section.settings.region_title != blank or section.settings.flag_image != blank %}
      <h2 class="fs-region__heading">
        {% if section.settings.region_title != blank %}
          <span class="fs-region__heading-text">{{ section.settings.region_title | escape }}</span>
        {% endif %}
        {% if section.settings.flag_image != blank %}
          <span class="fs-region__flag" aria-hidden="true">
            {{
              section.settings.flag_image
              | image_url: width: 128
              | image_tag:
                class: 'fs-region__flag-img',
                alt: '',
                loading: 'lazy',
                widths: '64, 96, 128',
                sizes: '(max-width: 749px) 28px, 34px'
            }}
          </span>
        {% endif %}
      </h2>
    {% endif %}

    {% if section.settings.sublabel != blank %}
      <h3 class="fs-region__sublabel">{{ section.settings.sublabel }}</h3>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="fs-region__grid" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="fs-region__logo-cell" role="listitem" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="fs-region__logo-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                  {% if block.settings.image != blank %}
                    {%- assign logo_alt = block.settings.image.alt | default: section.settings.region_title | escape -%}
                    {{
                      block.settings.image
                      | image_url: width: 400
                      | image_tag:
                        loading: 'lazy',
                        class: 'fs-region__logo-img',
                        alt: logo_alt
                    }}
                  {% endif %}
                </a>
              {% else %}
                {% if block.settings.image != blank %}
                  {%- assign logo_alt = block.settings.image.alt | default: section.settings.region_title | escape -%}
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      class: 'fs-region__logo-img',
                      alt: logo_alt
                  }}
                {% endif %}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.footer != blank %}
      <div class="fs-region__footer rte">
        {{ section.settings.footer }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Find store region",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "region_title",
      "label": "Region title",
      "default": "United States"
    },
    {
      "type": "image_picker",
      "id": "flag_image",
      "label": "Flag icon",
      "info": "Shown inline to the right of the title on desktop and mobile (e.g. country flag)."
    },
    {
      "type": "text",
      "id": "sublabel",
      "label": "Sublabel",
      "default": "Available at:"
    },
    {
      "type": "richtext",
      "id": "footer",
      "label": "Footer note",
      "default": "<p>Also available online at <strong>Kefey.co</strong></p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "title_font_family",
      "label": "Title font",
      "default": "heading",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size (px)",
      "min": 18,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Body font",
      "default": "body",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width (px)",
      "min": 800,
      "max": 1400,
      "step": 10,
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Find store region",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
