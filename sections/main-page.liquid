{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
{%- if use_legal_typography -%}
  {{ 'section-main-page-legal.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- liquid
  assign legal_title_ff = 'inherit'
  if section.settings.legal_title_font_family == 'heading'
    assign legal_title_ff = 'var(--font-heading-family)'
  elsif section.settings.legal_title_font_family == 'body'
    assign legal_title_ff = 'var(--font-body-family)'
  endif

  assign legal_section_ff = 'inherit'
  if section.settings.legal_section_font_family == 'heading'
    assign legal_section_ff = 'var(--font-heading-family)'
  elsif section.settings.legal_section_font_family == 'body'
    assign legal_section_ff = 'var(--font-body-family)'
  endif

  assign legal_body_ff = 'inherit'
  if section.settings.legal_body_font_family == 'heading'
    assign legal_body_ff = 'var(--font-heading-family)'
  elsif section.settings.legal_body_font_family == 'body'
    assign legal_body_ff = 'var(--font-body-family)'
  endif

  assign legal_title_transform = 'none'
  if section.settings.legal_title_uppercase
    assign legal_title_transform = 'uppercase'
  endif

  assign legal_section_transform = 'none'
  if section.settings.legal_section_heading_uppercase
    assign legal_section_transform = 'uppercase'
  endif

  assign legal_line_height = section.settings.legal_body_line_height | default: 165 | times: 0.01

  assign use_legal_typography = section.settings.enable_legal_typography
  if use_legal_typography == false and request.page_type == 'page' and page.handle != blank
    assign _policy_handles = settings.policy_layout_page_handles | default: 'consumer-health-data-privacy-policy, digital-accessibility-statement' | split: ','
    for _part in _policy_handles
      assign _h = _part | strip
      if _h != '' and page.handle == _h
        assign use_legal_typography = true
      endif
    endfor
  endif
  if use_legal_typography == false and template.suffix == 'terms'
    assign use_legal_typography = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if use_legal_typography -%}
    .kefey-main-page--legal.section-{{ section.id }}-padding {
      --legal-title-font-family: {{ legal_title_ff }};
      --legal-section-font-family: {{ legal_section_ff }};
      --legal-body-font-family: {{ legal_body_ff }};
      --legal-title-color: {{ section.settings.legal_title_color }};
      --legal-title-font-weight: {{ section.settings.legal_title_font_weight }};
      --legal-title-highlight-color: {{ section.settings.legal_title_highlight_color }};
      --legal-section-heading-color: {{ section.settings.legal_section_heading_color }};
      --legal-body-color: {{ section.settings.legal_body_color }};
      --legal-title-font-size: {{ section.settings.legal_title_font_size }}px;
      --legal-section-heading-font-size: {{ section.settings.legal_section_heading_font_size }}px;
      --legal-body-font-size: {{ section.settings.legal_body_font_size }}px;
      --legal-body-line-height: {{ legal_line_height }};
      --legal-paragraph-spacing: {{ section.settings.legal_paragraph_spacing }}px;
      --legal-content-max-width: {{ section.settings.legal_content_max_width }}px;
      --legal-title-text-transform: {{ legal_title_transform }};
      --legal-section-text-transform: {{ legal_section_transform }};
    }
  {%- endif -%}
{%- endstyle -%}

<div
  class="page-width page-width--narrow section-{{ section.id }}-padding{% if use_legal_typography %} kefey-main-page--legal{% endif %}"
>
  <h1 class="main-page-title page-title kefey-legal-page-title{% unless use_legal_typography %} h0{% endunless %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {%- if use_legal_typography -%}
      <span class="kefey-legal-page-title__text">{{ page.title | escape }}</span>
      <span class="kefey-legal-page-title__bar" aria-hidden="true"></span>
    {%- else -%}
      {{ page.title | escape }}
    {%- endif -%}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Legal & policy typography"
    },
    {
      "type": "paragraph",
      "content": "Turn on for Terms, Privacy, and similar long-form pages. Use the “page.terms” template to keep other pages unchanged, or enable here and adjust colors per store."
    },
    {
      "type": "checkbox",
      "id": "enable_legal_typography",
      "label": "Enable legal document typography",
      "default": false
    },
    {
      "type": "select",
      "id": "legal_title_font_family",
      "label": "Page title font",
      "default": "heading",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "legal_section_font_family",
      "label": "Section headings font (H2–H6 in content)",
      "default": "heading",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "legal_body_font_family",
      "label": "Body text font",
      "default": "body",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "color",
      "id": "legal_title_color",
      "label": "Page title color",
      "default": "#101010"
    },
    {
      "type": "color",
      "id": "legal_title_highlight_color",
      "label": "Page title highlight bar",
      "default": "#2BB4A7"
    },
    {
      "type": "select",
      "id": "legal_title_font_weight",
      "label": "Page title font weight",
      "default": "500",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "color",
      "id": "legal_section_heading_color",
      "label": "Section heading color",
      "default": "#101010"
    },
    {
      "type": "color",
      "id": "legal_body_color",
      "label": "Body text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "legal_title_font_size",
      "min": 20,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Page title font size",
      "default": 36
    },
    {
      "type": "range",
      "id": "legal_section_heading_font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Section heading font size",
      "default": 18
    },
    {
      "type": "range",
      "id": "legal_body_font_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Body font size",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "legal_title_uppercase",
      "label": "Uppercase page title",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "legal_section_heading_uppercase",
      "label": "Uppercase section headings in content",
      "default": true
    },
    {
      "type": "range",
      "id": "legal_body_line_height",
      "min": 130,
      "max": 200,
      "step": 5,
      "label": "Body line height",
      "default": 165,
      "info": "1.65 = 165"
    },
    {
      "type": "range",
      "id": "legal_paragraph_spacing",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Space below paragraphs & lists",
      "default": 16
    },
    {
      "type": "range",
      "id": "legal_content_max_width",
      "min": 480,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "label": "Content column max width",
      "default": 1160
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
