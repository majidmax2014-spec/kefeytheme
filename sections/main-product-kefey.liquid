{{ 'kefey-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kefey-product.js' | asset_url }}" defer></script>

{%- liquid
  assign kefey_product = product
  if kefey_product == blank and section.settings.product != blank
    assign kefey_product = section.settings.product
  endif
  if kefey_product == blank
    assign kefey_product = collections.all.products.first
  endif

  assign default_pack_num = section.settings.default_selected_pack | default: '2' | plus: 0

  assign single_product_image_url = ''
  if section.settings.pack_image_1 != blank
    assign single_product_image_url = section.settings.pack_image_1 | image_url: width: 820
  elsif kefey_product and kefey_product.featured_image
    assign single_product_image_url = kefey_product.featured_image | image_url: width: 820
  endif

  assign pack_image_2_url = single_product_image_url
  if section.settings.pack_image_2 != blank
    assign pack_image_2_url = section.settings.pack_image_2 | image_url: width: 820
  endif
  assign pack_image_3_url = single_product_image_url
  if section.settings.pack_image_3 != blank
    assign pack_image_3_url = section.settings.pack_image_3 | image_url: width: 820
  endif
  assign pack_image_4_url = single_product_image_url
  if section.settings.pack_image_4 != blank
    assign pack_image_4_url = section.settings.pack_image_4 | image_url: width: 820
  endif
  assign pack_image_5_url = single_product_image_url
  if section.settings.pack_image_5 != blank
    assign pack_image_5_url = section.settings.pack_image_5 | image_url: width: 820
  endif
  assign pack_image_6_url = single_product_image_url
  if section.settings.pack_image_6 != blank
    assign pack_image_6_url = section.settings.pack_image_6 | image_url: width: 820
  endif

  if section.settings.default_purchase_type == 'one'
    assign active_pack_image = section.settings.pack_image_1
  elsif default_pack_num == 6 and section.settings.pack_image_6 != blank
    assign active_pack_image = section.settings.pack_image_6
  elsif default_pack_num == 5 and section.settings.pack_image_5 != blank
    assign active_pack_image = section.settings.pack_image_5
  elsif default_pack_num == 4 and section.settings.pack_image_4 != blank
    assign active_pack_image = section.settings.pack_image_4
  elsif default_pack_num == 3 and section.settings.pack_image_3 != blank
    assign active_pack_image = section.settings.pack_image_3
  elsif default_pack_num == 2 and section.settings.pack_image_2 != blank
    assign active_pack_image = section.settings.pack_image_2
  else
    assign active_pack_image = section.settings.pack_image_1
  endif
  if active_pack_image == blank and kefey_product and kefey_product.featured_image
    assign active_pack_image = kefey_product.featured_image
  endif
  assign active_pack_image_url = active_pack_image | image_url: width: 820
-%}

<section class="kefey-product kefey-product-main" id="KefeyProductMain-{{ section.id }}">
  <div class="page-width">
    <div
      id="kefey-purchase"
      class="kefey-purchase"
      data-kefey-purchase
      data-default-pack="{{ section.settings.default_selected_pack }}"
      data-default-purchase-type="{{ section.settings.default_purchase_type }}"
      data-discount-percent="{{ section.settings.subscription_discount_percent }}"
      data-discount-pack-2="{{ section.settings.subscription_discount_pack_2 }}"
      data-discount-pack-3="{{ section.settings.subscription_discount_pack_3 }}"
      data-discount-pack-4="{{ section.settings.subscription_discount_pack_4 }}"
      data-discount-pack-5="{{ section.settings.subscription_discount_pack_5 }}"
      data-discount-pack-6="{{ section.settings.subscription_discount_pack_6 }}"
      data-badge-text="{{ section.settings.badge_text | escape }}"
      data-display-compare="{{ section.settings.display_compare_price }}"
      data-money-format="{{ shop.money_format | escape }}"
      data-plan-pack-2="{{ section.settings.plan_id_pack_2 }}"
      data-plan-pack-3="{{ section.settings.plan_id_pack_3 }}"
      data-plan-pack-4="{{ section.settings.plan_id_pack_4 }}"
      data-plan-pack-5="{{ section.settings.plan_id_pack_5 }}"
      data-plan-pack-6="{{ section.settings.plan_id_pack_6 }}"
      data-plan-group-pack-2="{{ section.settings.plan_group_id_pack_2 }}"
      data-plan-group-pack-3="{{ section.settings.plan_group_id_pack_3 }}"
      data-plan-group-pack-4="{{ section.settings.plan_group_id_pack_4 }}"
      data-plan-group-pack-5="{{ section.settings.plan_group_id_pack_5 }}"
      data-plan-group-pack-6="{{ section.settings.plan_group_id_pack_6 }}"
      {%- if single_product_image_url != blank -%}
        data-single-product-image="{{ single_product_image_url }}"
      {%- endif -%}
      {%- if pack_image_2_url != blank -%}
        data-pack-image-2="{{ pack_image_2_url }}"
      {%- endif -%}
      {%- if pack_image_3_url != blank -%}
        data-pack-image-3="{{ pack_image_3_url }}"
      {%- endif -%}
      {%- if pack_image_4_url != blank -%}
        data-pack-image-4="{{ pack_image_4_url }}"
      {%- endif -%}
      {%- if pack_image_5_url != blank -%}
        data-pack-image-5="{{ pack_image_5_url }}"
      {%- endif -%}
      {%- if pack_image_6_url != blank -%}
        data-pack-image-6="{{ pack_image_6_url }}"
      {%- endif -%}
      style="
        --kp-highlight: {{ section.settings.highlight_bar_color }};
        --kp-subscribe-bg: {{ section.settings.subscribe_card_bg }};
        --kp-onetime-bg: {{ section.settings.onetime_card_bg }};
        --kp-cta-bg: {{ section.settings.cta_bg_color }};
        --kp-cta-color: {{ section.settings.cta_text_color }};
        --kp-h-ff: {{ section.settings.heading_font_family }};
        --kp-h-fs-d: {{ section.settings.heading_font_size_desktop }}px;
        --kp-h-fs-m: {{ section.settings.heading_font_size_mobile }}px;
        --kp-h-fw: {{ section.settings.heading_font_weight }};
        --kp-t-ff: {{ section.settings.text_font_family }};
        --kp-t-fs-d: {{ section.settings.text_font_size_desktop }}px;
        --kp-t-fs-m: {{ section.settings.text_font_size_mobile }}px;
        --kp-t-fw: {{ section.settings.text_font_weight }};
        --kp-p-ff: {{ section.settings.price_font_family }};
        --kp-p-fs-d: {{ section.settings.price_font_size_desktop }}px;
        --kp-p-fs-m: {{ section.settings.price_font_size_mobile }}px;
        --kp-p-fw: {{ section.settings.price_font_weight }};
      "
    >
      <header class="kefey-purchase__header">
        <h2 class="kefey-purchase__heading"><span>{{ section.settings.purchase_heading }}</span></h2>
        <p class="kefey-purchase__subheading">{{ section.settings.purchase_subheading }}</p>
        <p class="kefey-purchase__note">{{ section.settings.purchase_note }}</p>
      </header>

      <div class="kefey-purchase__grid">
        <div class="kefey-purchase__left">
          <div class="kefey-purchase__image-card">
            {%- if active_pack_image != blank -%}
              {{
                active_pack_image
                | image_url: width: 820
                | image_tag:
                  class: 'kefey-purchase__image',
                  widths: '360, 560, 760, 820',
                  sizes: '(min-width: 990px) 440px, 90vw',
                  loading: 'lazy',
                  alt: kefey_product.title,
                  data-kefey-pack-image: '',
                  data-fallback-src: active_pack_image_url
              }}
            {%- endif -%}
          </div>
        </div>

        <div class="kefey-purchase__right">
          <div class="kefey-purchase__plans">
            <div class="kefey-purchase__subscribe-group">
              <button class="kefey-purchase__plan kefey-purchase__plan--subscribe" type="button" data-plan="sub">
                <span class="kefey-purchase__badge" data-sub-badge>{{ section.settings.badge_text }}</span>
                <span class="kefey-purchase__plan-title">{{ section.settings.sub_label }}</span>
                <span class="kefey-purchase__price-row">
                  <span class="kefey-purchase__price" data-sub-each>{{ section.settings.fallback_price }}</span>
                  <span class="kefey-purchase__each">each</span>
                  <span class="kefey-purchase__total">Total: <span data-sub-total>{{ section.settings.fallback_price }}</span></span>
                  <span class="kefey-purchase__compare" data-sub-compare>{{ section.settings.display_compare_price }}</span>
                </span>
              </button>

              <div class="kefey-purchase__packs" data-subscribe-packs role="group" aria-label="Pack selector">
                <button class="kefey-purchase__pack" type="button" data-pack="6">{{ section.settings.pack_label_6 }}</button>
                <button class="kefey-purchase__pack" type="button" data-pack="5">{{ section.settings.pack_label_5 }}</button>
                <button class="kefey-purchase__pack" type="button" data-pack="4">{{ section.settings.pack_label_4 }}</button>
                <button class="kefey-purchase__pack" type="button" data-pack="3">{{ section.settings.pack_label_3 }}</button>
                <button class="kefey-purchase__pack" type="button" data-pack="2">{{ section.settings.pack_label_2 }}</button>
              </div>
            </div>

            <button class="kefey-purchase__plan kefey-purchase__plan--one-time" type="button" data-plan="one">
              <span class="kefey-purchase__plan-title">{{ section.settings.onetime_label }}</span>
              <span class="kefey-purchase__price-row">
                <span class="kefey-purchase__price" data-one-each>{{ section.settings.fallback_price }}</span>
                <span class="kefey-purchase__each">each</span>
              </span>
            </button>
          </div>
        </div>
      </div>
      <div class="kefey-purchase__cta-row">
        <input type="hidden" value="{{ kefey_product.selected_or_first_available_variant.id }}" data-selected-variant-id>
        <button class="kefey-purchase__cta" type="button" data-kefey-checkout>
          {{ section.settings.atc_label }}
        </button>
      </div>

      {%- if kefey_product -%}
        <script type="application/json" data-kefey-product-json>{{ kefey_product | json }}</script>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Product Kefey",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "purchase_heading", "label": "Purchase heading", "default": "Never Run Out of Joy" },
    { "type": "text", "id": "purchase_subheading", "label": "Purchase subheading", "default": "More Stars | More Balance | More Smiles" },
    { "type": "text", "id": "purchase_note", "label": "Purchase red note", "default": "Subscribe & receive your Kefey® Mood Gummies monthly." },
    { "type": "text", "id": "preview_text", "label": "Preview helper text", "default": "Mood support gummies · 60 count" },
    { "type": "text", "id": "sub_label", "label": "Subscription label", "default": "Subscribe & Save" },
    { "type": "text", "id": "onetime_label", "label": "One-time label", "default": "One-time Purchase" },
    { "type": "text", "id": "sub_badge", "label": "Subscription badge text", "default": "SAVE 15% + FREE SHIPPING" },
    { "type": "text", "id": "onetime_badge", "label": "One-time badge text", "default": "STANDARD PRICING" },
    { "type": "text", "id": "badge_text", "label": "Top-right badge", "default": "10% OFF & Cancel Anytime" },
    { "type": "header", "content": "Subscription discount by bundle" },
    { "type": "range", "id": "subscription_discount_pack_2", "label": "Bundle 2 subscription discount %", "min": 0, "max": 50, "step": 1, "default": 0, "unit": "%" },
    { "type": "range", "id": "subscription_discount_pack_3", "label": "Bundle 3 subscription discount %", "min": 0, "max": 50, "step": 1, "default": 15, "unit": "%" },
    { "type": "range", "id": "subscription_discount_pack_4", "label": "Bundle 4 subscription discount %", "min": 0, "max": 50, "step": 1, "default": 20, "unit": "%" },
    { "type": "range", "id": "subscription_discount_pack_5", "label": "Bundle 5 subscription discount %", "min": 0, "max": 50, "step": 1, "default": 30, "unit": "%" },
    { "type": "range", "id": "subscription_discount_pack_6", "label": "Bundle 6 subscription discount %", "min": 0, "max": 50, "step": 1, "default": 35, "unit": "%" },
    { "type": "range", "id": "subscription_discount_percent", "label": "Subscription discount % (display)", "min": 0, "max": 50, "step": 1, "default": 10, "unit": "%" },
    { "type": "text", "id": "display_compare_price", "label": "Display compare price fallback", "default": "$75.00" },
    { "type": "text", "id": "fallback_price", "label": "Fallback price text", "default": "$39.00" },
    { "type": "text", "id": "pack_label_6", "label": "6 pack label", "default": "6 - Pack" },
    { "type": "text", "id": "pack_label_5", "label": "5 pack label", "default": "5 - Pack" },
    { "type": "text", "id": "pack_label_4", "label": "4 pack label", "default": "4 - Pack" },
    { "type": "text", "id": "pack_label_3", "label": "3 pack label", "default": "3 - Pack" },
    { "type": "text", "id": "pack_label_2", "label": "2 pack label", "default": "2 - Pack" },
    { "type": "header", "content": "Pack preview images" },
    { "type": "image_picker", "id": "pack_image_1", "label": "Single product image (one-time purchase)" },
    { "type": "image_picker", "id": "pack_image_2", "label": "2 pack image" },
    { "type": "image_picker", "id": "pack_image_3", "label": "3 pack image" },
    { "type": "image_picker", "id": "pack_image_4", "label": "4 pack image" },
    { "type": "image_picker", "id": "pack_image_5", "label": "5 pack image" },
    { "type": "image_picker", "id": "pack_image_6", "label": "6 pack image" },
    { "type": "header", "content": "Recharge plan mapping by pack" },
    { "type": "text", "id": "plan_id_pack_2", "label": "Bundle 2 selling plan ID", "default": "7728955620", "info": "Recharge External plan ID (Shopify selling plan ID)." },
    { "type": "text", "id": "plan_id_pack_3", "label": "Bundle 3 selling plan ID", "default": "7728857316", "info": "Recharge External plan ID (Shopify selling plan ID)." },
    { "type": "text", "id": "plan_id_pack_4", "label": "Bundle 4 selling plan ID", "default": "7838564580", "info": "Recharge External plan ID (Shopify selling plan ID)." },
    { "type": "text", "id": "plan_id_pack_5", "label": "Bundle 5 selling plan ID", "default": "7728890084", "info": "Recharge External plan ID (Shopify selling plan ID)." },
    { "type": "text", "id": "plan_id_pack_6", "label": "Bundle 6 selling plan ID", "default": "7838597348", "info": "Recharge External plan ID (Shopify selling plan ID)." },
    { "type": "text", "id": "plan_group_id_pack_2", "label": "Bundle 2 plan group ID", "default": "4301095140", "info": "Recharge External plan group ID fallback for matching." },
    { "type": "text", "id": "plan_group_id_pack_3", "label": "Bundle 3 plan group ID", "default": "4301029604", "info": "Recharge External plan group ID fallback for matching." },
    { "type": "text", "id": "plan_group_id_pack_4", "label": "Bundle 4 plan group ID", "default": "4403331300", "info": "Recharge External plan group ID fallback for matching." },
    { "type": "text", "id": "plan_group_id_pack_5", "label": "Bundle 5 plan group ID", "default": "4301062372", "info": "Recharge External plan group ID fallback for matching." },
    { "type": "text", "id": "plan_group_id_pack_6", "label": "Bundle 6 plan group ID", "default": "4403364068", "info": "Recharge External plan group ID fallback for matching." },
    {
      "type": "select",
      "id": "default_selected_pack",
      "label": "Default selected pack",
      "default": "2",
      "options": [
        { "value": "2", "label": "2 pack" },
        { "value": "3", "label": "3 pack" },
        { "value": "4", "label": "4 pack" },
        { "value": "5", "label": "5 pack" },
        { "value": "6", "label": "6 pack" }
      ]
    },
    {
      "type": "select",
      "id": "default_purchase_type",
      "label": "Default purchase type",
      "default": "sub",
      "options": [
        { "value": "sub", "label": "Subscribe" },
        { "value": "one", "label": "One-time" }
      ]
    },
    { "type": "color", "id": "highlight_bar_color", "label": "Heading highlight color", "default": "#f4c820" },
    { "type": "color", "id": "subscribe_card_bg", "label": "Subscribe card background", "default": "#f4ca2a" },
    { "type": "color", "id": "onetime_card_bg", "label": "One-time card background", "default": "#49afb4" },
    { "type": "color", "id": "cta_bg_color", "label": "Checkout button background", "default": "#111111" },
    { "type": "color", "id": "cta_text_color", "label": "Checkout button text color", "default": "#ffffff" },
    { "type": "header", "content": "Heading Typography" },
    { "type": "text", "id": "heading_font_family", "label": "Heading font family", "default": "inherit" },
    { "type": "range", "id": "heading_font_size_desktop", "label": "Heading font size desktop", "min": 20, "max": 80, "step": 1, "default": 56, "unit": "px" },
    { "type": "range", "id": "heading_font_size_mobile", "label": "Heading font size mobile", "min": 16, "max": 52, "step": 1, "default": 34, "unit": "px" },
    { "type": "range", "id": "heading_font_weight", "label": "Heading font weight", "min": 300, "max": 900, "step": 100, "default": 700 },
    { "type": "header", "content": "Text Typography" },
    { "type": "text", "id": "text_font_family", "label": "Text font family", "default": "inherit" },
    { "type": "range", "id": "text_font_size_desktop", "label": "Text font size desktop", "min": 12, "max": 40, "step": 1, "default": 20, "unit": "px" },
    { "type": "range", "id": "text_font_size_mobile", "label": "Text font size mobile", "min": 10, "max": 32, "step": 1, "default": 16, "unit": "px" },
    { "type": "range", "id": "text_font_weight", "label": "Text font weight", "min": 300, "max": 900, "step": 100, "default": 500 },
    { "type": "header", "content": "Price Typography" },
    { "type": "text", "id": "price_font_family", "label": "Price font family", "default": "inherit" },
    { "type": "range", "id": "price_font_size_desktop", "label": "Price font size desktop", "min": 20, "max": 96, "step": 1, "default": 72, "unit": "px" },
    { "type": "range", "id": "price_font_size_mobile", "label": "Price font size mobile", "min": 18, "max": 72, "step": 1, "default": 48, "unit": "px" },
    { "type": "range", "id": "price_font_weight", "label": "Price font weight", "min": 300, "max": 900, "step": 100, "default": 700 },
    { "type": "text", "id": "atc_label", "label": "Add to cart label", "default": "ADD TO CART" },
    { "type": "text", "id": "trust_text", "label": "Trust microcopy", "default": "Free U.S. shipping over $50 · 30-day happiness guarantee" }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Main Product Kefey"
    }
  ]
}
{% endschema %}
