{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign offers_heading_ff = 'inherit'
  if section.settings.offers_heading_font_family == 'heading'
    assign offers_heading_ff = 'var(--font-heading-family)'
  elsif section.settings.offers_heading_font_family == 'body'
    assign offers_heading_ff = 'var(--font-body-family)'
  endif

  assign offer_title_ff = 'inherit'
  if section.settings.offer_title_font_family == 'heading'
    assign offer_title_ff = 'var(--font-heading-family)'
  elsif section.settings.offer_title_font_family == 'body'
    assign offer_title_ff = 'var(--font-body-family)'
  endif

  assign offer_line_ff = 'inherit'
  if section.settings.offer_line_font_family == 'heading'
    assign offer_line_ff = 'var(--font-heading-family)'
  elsif section.settings.offer_line_font_family == 'body'
    assign offer_line_ff = 'var(--font-body-family)'
  endif

  assign offer_button_ff = 'inherit'
  if section.settings.offer_button_font_family == 'heading'
    assign offer_button_ff = 'var(--font-heading-family)'
  elsif section.settings.offer_button_font_family == 'body'
    assign offer_button_ff = 'var(--font-body-family)'
  endif

  assign table_heading_ff = 'inherit'
  if section.settings.table_heading_font_family == 'heading'
    assign table_heading_ff = 'var(--font-heading-family)'
  elsif section.settings.table_heading_font_family == 'body'
    assign table_heading_ff = 'var(--font-body-family)'
  endif

  assign product_title_ff = 'inherit'
  if section.settings.product_title_font_family == 'heading'
    assign product_title_ff = 'var(--font-heading-family)'
  elsif section.settings.product_title_font_family == 'body'
    assign product_title_ff = 'var(--font-body-family)'
  endif

  assign product_meta_ff = 'inherit'
  if section.settings.product_meta_font_family == 'heading'
    assign product_meta_ff = 'var(--font-heading-family)'
  elsif section.settings.product_meta_font_family == 'body'
    assign product_meta_ff = 'var(--font-body-family)'
  endif

  assign product_price_ff = 'inherit'
  if section.settings.product_price_font_family == 'heading'
    assign product_price_ff = 'var(--font-heading-family)'
  elsif section.settings.product_price_font_family == 'body'
    assign product_price_ff = 'var(--font-body-family)'
  endif

  assign upsell_label_ff = 'inherit'
  if section.settings.upsell_label_font_family == 'heading'
    assign upsell_label_ff = 'var(--font-heading-family)'
  elsif section.settings.upsell_label_font_family == 'body'
    assign upsell_label_ff = 'var(--font-body-family)'
  endif

  assign upsell_button_ff = 'inherit'
  if section.settings.upsell_button_font_family == 'heading'
    assign upsell_button_ff = 'var(--font-heading-family)'
  elsif section.settings.upsell_button_font_family == 'body'
    assign upsell_button_ff = 'var(--font-body-family)'
  endif

  assign upsell_total_ff = 'inherit'
  if section.settings.upsell_total_font_family == 'heading'
    assign upsell_total_ff = 'var(--font-heading-family)'
  elsif section.settings.upsell_total_font_family == 'body'
    assign upsell_total_ff = 'var(--font-body-family)'
  endif

  assign remove_label_ff = 'inherit'
  if section.settings.remove_font_family == 'heading'
    assign remove_label_ff = 'var(--font-heading-family)'
  elsif section.settings.remove_font_family == 'body'
    assign remove_label_ff = 'var(--font-body-family)'
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .kefey-cart-page {
    --k-offers-heading-family: {{ offers_heading_ff }};
    --k-offers-heading-size: {{ section.settings.offers_heading_font_size }}px;
    --k-offers-heading-weight: {{ section.settings.offers_heading_font_weight }};

    --k-offer-title-family: {{ offer_title_ff }};
    --k-offer-title-size: {{ section.settings.offer_title_font_size }}px;
    --k-offer-title-weight: {{ section.settings.offer_title_font_weight }};

    --k-offer-line-family: {{ offer_line_ff }};
    --k-offer-line1-size: {{ section.settings.offer_line1_font_size }}px;
    --k-offer-line2-size: {{ section.settings.offer_line2_font_size }}px;
    --k-offer-line-weight: {{ section.settings.offer_line_font_weight }};

    --k-offer-button-family: {{ offer_button_ff }};
    --k-offer-button-size: {{ section.settings.offer_button_font_size }}px;
    --k-offer-button-weight: {{ section.settings.offer_button_font_weight }};

    --k-table-heading-family: {{ table_heading_ff }};
    --k-table-heading-size: {{ section.settings.table_heading_font_size }}px;
    --k-table-heading-weight: {{ section.settings.table_heading_font_weight }};

    --k-product-title-family: {{ product_title_ff }};
    --k-product-title-size: {{ section.settings.product_title_font_size }}px;
    --k-product-title-weight: {{ section.settings.product_title_font_weight }};

    --k-product-meta-family: {{ product_meta_ff }};
    --k-product-meta-size: {{ section.settings.product_meta_font_size }}px;
    --k-product-meta-weight: {{ section.settings.product_meta_font_weight }};

    --k-product-price-family: {{ product_price_ff }};
    --k-product-price-size: {{ section.settings.product_price_font_size }}px;
    --k-product-price-weight: {{ section.settings.product_price_font_weight }};

    --k-upsell-label-family: {{ upsell_label_ff }};
    --k-upsell-label-size: {{ section.settings.upsell_label_font_size }}px;
    --k-upsell-label-weight: {{ section.settings.upsell_label_font_weight }};

    --k-upsell-button-family: {{ upsell_button_ff }};
    --k-upsell-button-size: {{ section.settings.upsell_button_font_size }}px;
    --k-upsell-button-weight: {{ section.settings.upsell_button_font_weight }};

    --k-upsell-total-family: {{ upsell_total_ff }};
    --k-upsell-total-size: {{ section.settings.upsell_total_font_size }}px;
    --k-upsell-total-weight: {{ section.settings.upsell_total_font_weight }};

    --k-remove-family: {{ remove_label_ff }};
    --k-remove-size: {{ section.settings.remove_font_size }}px;
    --k-remove-weight: {{ section.settings.remove_font_weight }};

    --k-qty-size: {{ section.settings.quantity_font_size | default: 16 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<script src="{{ 'kefey-cart-offers.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'kefey-cart-upsell-guard.js' | asset_url }}" defer="defer"></script>

<cart-items class="kefey-cart-page section-{{ section.id }}-padding{% if cart == empty %} is-empty{% endif %}">
  <div class="page-width kefey-cart-shell">
    <div class="cart__warnings kefey-cart-warnings--hidden" hidden>
      <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
    </div>

    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          <div class="kefey-cart-offers" aria-label="Cart offers">
              {%- if section.settings.offers_heading != blank -%}
                <h2 class="kefey-cart-offers__heading">
                  <span>{{ section.settings.offers_heading }}</span>
                </h2>
              {%- endif -%}

              <div class="kefey-cart-offers__grid">
                <article class="kefey-cart-offer-card">
                  {%- if section.settings.offer_left_image != blank -%}
                    <div class="kefey-cart-offer-card__image-wrap">
                      {{
                        section.settings.offer_left_image
                        | image_url: width: 260
                        | image_tag:
                          loading: 'lazy',
                          widths: '140,180,220,260',
                          class: 'kefey-cart-offer-card__image',
                          alt: section.settings.offer_left_title
                      }}
                    </div>
                  {%- endif -%}

                  <div class="kefey-cart-offer-card__content">
                    <h3>{{ section.settings.offer_left_title }}</h3>
                    <p class="kefey-cart-offer-card__copy">
                      {%- if section.settings.offer_left_line1 != blank -%}
                        {{- section.settings.offer_left_line1 -}}
                      {%- endif -%}
                      {%- if section.settings.offer_left_line1 != blank and section.settings.offer_left_line2 != blank -%}
                        {{ ' ' }}
                      {%- endif -%}
                      {%- if section.settings.offer_left_line2 != blank -%}
                        {{- section.settings.offer_left_line2 -}}
                      {%- endif -%}
                    </p>
                    {%- if section.settings.offer_left_button_label != blank -%}
                      <button
                        type="button"
                        class="kefey-cart-offer-card__button"
                        data-cart-offer-button
                        data-bundle-key="big-smile"
                        data-bundle-discount="25"
                        data-variant-id="{{ section.settings.offer_left_variant_id | strip }}"
                        data-quantity="{{ section.settings.offer_left_quantity }}"
                        data-discount-code="{{ section.settings.offer_left_discount_code | strip }}"
                        data-fallback-url="{{ section.settings.offer_left_button_link | default: '#' }}"
                      >
                        {{ section.settings.offer_left_button_label }}
                      </button>
                    {%- endif -%}
                  </div>
                </article>

                <article class="kefey-cart-offer-card">
                  <div class="kefey-cart-offer-card__content">
                    <h3>{{ section.settings.offer_right_title }}</h3>
                    <p class="kefey-cart-offer-card__copy">
                      {%- if section.settings.offer_right_line1 != blank -%}
                        {{- section.settings.offer_right_line1 -}}
                      {%- endif -%}
                      {%- if section.settings.offer_right_line1 != blank and section.settings.offer_right_line2 != blank -%}
                        {{ ' ' }}
                      {%- endif -%}
                      {%- if section.settings.offer_right_line2 != blank -%}
                        {{- section.settings.offer_right_line2 -}}
                      {%- endif -%}
                    </p>
                    {%- if section.settings.offer_right_button_label != blank -%}
                      <button
                        type="button"
                        class="kefey-cart-offer-card__button"
                        data-cart-offer-button
                        data-bundle-key="joyful-trio"
                        data-bundle-discount="15"
                        data-variant-id="{{ section.settings.offer_right_variant_id | strip }}"
                        data-quantity="{{ section.settings.offer_right_quantity }}"
                        data-discount-code="{{ section.settings.offer_right_discount_code | strip }}"
                        data-fallback-url="{{ section.settings.offer_right_button_link | default: '#' }}"
                      >
                        {{ section.settings.offer_right_button_label }}
                      </button>
                    {%- endif -%}
                  </div>

                  {%- if section.settings.offer_right_image != blank -%}
                    <div class="kefey-cart-offer-card__image-wrap kefey-cart-offer-card__image-wrap--right">
                      {{
                        section.settings.offer_right_image
                        | image_url: width: 260
                        | image_tag:
                          loading: 'lazy',
                          widths: '140,180,220,260',
                          class: 'kefey-cart-offer-card__image',
                          alt: section.settings.offer_right_title
                      }}
                    </div>
                  {%- endif -%}
                </article>
              </div>
            </div>

          {%- if cart == empty -%}
            <div class="kefey-cart-empty-items">
              <p class="kefey-cart-empty-items__text">{{ 'sections.cart.empty' | t }}</p>
            </div>
          {%- else -%}
            <table class="cart-items kefey-cart-table" role="table">
              <caption class="visually-hidden">
                {{ 'sections.cart.title' | t }}
              </caption>
              <thead>
                <tr>
                  <th scope="col">{{ 'sections.cart.headings.product' | t }}</th>
                  <th scope="col" class="kefey-cart-table__qty-heading">{{ 'sections.cart.headings.quantity' | t }}</th>
                  <th scope="col" class="kefey-cart-table__total-heading">{{ 'sections.cart.headings.total' | t }}</th>
                </tr>
              </thead>

              <tbody>
                {%- for item in cart.items -%}
                  {%- liquid
                    assign bundle_discount_pct = item.properties._kefey_bundle_discount | plus: 0
                    assign bundle_discount_label = item.properties._kefey_bundle_discount_label | default: ''
                    assign is_kefey_bundle = false
                    if item.properties._kefey_bundle != blank and bundle_discount_pct > 0
                      assign is_kefey_bundle = true
                    endif

                    assign is_kefey_upsell = false
                    if item.properties._kefey_upsell != blank
                      assign is_kefey_upsell = true
                    endif

                    assign is_kefey_purchase = false
                    if item.properties._kefey_purchase_type != blank
                      assign is_kefey_purchase = true
                    endif

                    assign is_kefey_sub_purchase = false
                    if item.properties._kefey_purchase_type == 'sub'
                      assign is_kefey_sub_purchase = true
                    endif

                    assign kefey_pack_image_url = item.properties._kefey_pack_image | default: ''
                    assign kefey_display_quantity = item.quantity
                    if is_kefey_sub_purchase and item.properties._kefey_pack_size != blank
                      assign kefey_display_quantity = item.properties._kefey_pack_size | plus: 0
                    endif

                    assign bundle_unit_final = item.original_price
                    assign bundle_line_final = item.original_line_price

                    if is_kefey_bundle
                      assign bundle_discount_amount = item.original_price | times: bundle_discount_pct | divided_by: 100
                      assign bundle_unit_final = item.original_price | minus: bundle_discount_amount
                      assign bundle_line_final = bundle_unit_final | times: item.quantity
                    endif

                    assign upsell_discount_pct = 10
                    assign upsell_unit_final = item.original_price
                    assign upsell_line_final = item.original_line_price

                    if is_kefey_upsell
                      assign upsell_discount_amount = item.original_price | times: upsell_discount_pct | divided_by: 100
                      assign upsell_unit_final = item.original_price | minus: upsell_discount_amount
                      assign upsell_line_final = upsell_unit_final | times: item.quantity
                    endif

                    assign upsell_discount_label = section.settings.upsell_discount_code | default: 'SAVE10'
                  -%}
                  <tr class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">
                    <td>
                      <div class="kefey-cart-product">
                        <div class="cart-item__media">
                          {%- if kefey_pack_image_url != blank -%}
                            <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"> </a>
                            <div class="cart-item__image-container kefey-cart-item__image-container">
                              <img
                                src="{{ kefey_pack_image_url }}"
                                class="cart-item__image kefey-cart-item__image"
                                alt="{{ item.product.title | escape }}"
                                loading="lazy"
                                width="92"
                                height="92"
                              >
                            </div>
                          {%- elsif item.image -%}
                            <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"> </a>
                            <div class="cart-item__image-container kefey-cart-item__image-container">
                              <img
                                src="{{ item.image | image_url: width: 220 }}"
                                class="cart-item__image kefey-cart-item__image"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="92"
                                height="92"
                              >
                            </div>
                          {%- endif -%}
                        </div>

                        <div class="cart-item__details">
                          <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title | escape }}</a>

                          {%- if item.selling_plan_allocation != null -%}
                            <p class="kefey-cart-plan">{{ item.selling_plan_allocation.selling_plan.name | upcase }}</p>
                            <a class="kefey-cart-switch-link" href="{{ item.url }}">
                              {{ section.settings.switch_purchase_label }}
                            </a>
                          {%- endif -%}

                          {%- if is_kefey_bundle -%}
                            <div class="cart-item__discounted-prices">
                              <s class="cart-item__old-price">{{ item.original_price | money }}</s>
                              <strong class="cart-item__final-price">{{ bundle_unit_final | money }}</strong>
                            </div>
                          {%- elsif is_kefey_upsell -%}
                            <div class="cart-item__discounted-prices">
                              <s class="cart-item__old-price">{{ item.original_price | money }}</s>
                              <strong class="cart-item__final-price">{{ upsell_unit_final | money }}</strong>
                            </div>
                          {%- elsif item.selling_plan_allocation != null and item.original_price != item.final_price -%}
                            <div class="cart-item__discounted-prices">
                              <s class="cart-item__old-price">{{ item.original_price | money }}</s>
                              <strong class="cart-item__final-price">{{ item.final_price | money }}</strong>
                            </div>
                          {%- elsif item.selling_plan_allocation != null -%}
                            <div class="kefey-cart-unit-price">{{ item.original_price | money }}</div>
                          {%- else -%}
                            <div class="kefey-cart-unit-price">{{ item.original_price | money }}</div>
                          {%- endif -%}

                          <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                            {%- if is_kefey_bundle and bundle_discount_label != blank -%}
                              <li class="discounts__discount">
                                {{- 'icon-discount.svg' | inline_asset_content -}}
                                {{ bundle_discount_label | escape }}
                              </li>
                            {%- elsif is_kefey_upsell and upsell_discount_label != blank -%}
                              <li class="discounts__discount">
                                {{- 'icon-discount.svg' | inline_asset_content -}}
                                {{ upsell_discount_label | escape }}
                              </li>
                            {%- elsif item.selling_plan_allocation != null -%}
                              {%- for discount in item.line_level_discount_allocations -%}
                                <li class="discounts__discount">
                                  {{- 'icon-discount.svg' | inline_asset_content -}}
                                  {{ discount.discount_application.title | escape }}
                                </li>
                              {%- endfor -%}
                            {%- endif -%}
                          </ul>
                        </div>
                      </div>
                    </td>

                    <td class="cart-item__quantity">
                      {%- render 'loading-spinner' -%}
                      <div class="kefey-cart-qty-wrap">
                        <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                          {{ 'products.product.quantity.label' | t }}
                        </label>

                        <quantity-input class="quantity cart-quantity">
                          {% assign can_update_quantity = item.instructions.can_update_quantity | default: true %}
                          {%- if item.properties._kefey_bundle != blank -%}
                            {% assign can_update_quantity = false %}
                          {%- endif -%}
                          {%- if is_kefey_sub_purchase -%}
                            {% assign can_update_quantity = false %}
                          {%- endif -%}
                          <button
                            class="quantity__button"
                            name="minus"
                            type="button"
                            {% if can_update_quantity == false %}
                              disabled
                            {% endif %}
                          >
                            <span class="visually-hidden">
                              {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                            </span>
                            -
                          </button>
                          {%- if is_kefey_sub_purchase -%}
                            <input type="hidden" name="updates[]" value="{{ item.quantity }}">
                          {%- endif -%}
                          <input
                            class="quantity__input"
                            data-quantity-variant-id="{{ item.variant.id }}"
                            type="number"
                            {% unless is_kefey_sub_purchase %}
                              name="updates[]"
                            {% endunless %}
                            {%- if is_kefey_sub_purchase -%}
                              value="{{ kefey_display_quantity }}"
                            {%- else -%}
                              value="{{ item.quantity }}"
                              {% # theme-check-disable %}
                              data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                              min="0"
                              data-min="{{ item.variant.quantity_rule.min }}"
                              {% if item.variant.quantity_rule.max != null %}
                                max="{{ item.variant.quantity_rule.max }}"
                              {% endif %}
                              step="{{ item.variant.quantity_rule.increment }}"
                              {% # theme-check-enable %}
                            {%- endif -%}
                            aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                            id="Quantity-{{ item.index | plus: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                            {% if can_update_quantity == false %}
                              disabled
                            {% endif %}
                          >
                          <button
                            class="quantity__button"
                            name="plus"
                            type="button"
                            {% if can_update_quantity == false %}
                              disabled
                            {% endif %}
                          >
                            <span class="visually-hidden">
                              {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                            </span>
                            +
                          </button>
                        </quantity-input>

                        <cart-remove-button
                          id="Remove-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                          {% assign can_remove = item.instructions.can_remove | default: true %}
                          {% if can_remove == false %}
                            class="hidden"
                          {% endif %}
                        >
                          <a
                            href="{{ item.url_to_remove }}"
                            class="kefey-cart-remove"
                            aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                          >
                            {{ section.settings.remove_label }}
                          </a>
                        </cart-remove-button>
                      </div>

                      <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                        <small class="cart-item__error-text"></small>
                        <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                      </div>
                    </td>

                    <td class="cart-item__totals right">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                        {%- if is_kefey_bundle -%}
                          <dl class="cart-item__discounted-prices">
                            <dd>
                              <s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s>
                            </dd>
                            <dd class="price price--end">{{ bundle_line_final | money }}</dd>
                          </dl>
                        {%- elsif is_kefey_upsell -%}
                          <dl class="cart-item__discounted-prices">
                            <dd>
                              <s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s>
                            </dd>
                            <dd class="price price--end">{{ upsell_line_final | money }}</dd>
                          </dl>
                        {%- elsif item.selling_plan_allocation != null and item.original_line_price != item.final_line_price -%}
                          <dl class="cart-item__discounted-prices">
                            <dd>
                              <s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s>
                            </dd>
                            <dd class="price price--end">{{ item.final_line_price | money }}</dd>
                          </dl>
                        {%- else -%}
                          <span class="price price--end">{{ item.original_line_price | money }}</span>
                        {%- endif -%}
                      </div>
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- endif -%}

          {%- liquid
            assign kefey_display_total = 0
            if cart != empty
              for item in cart.items
                assign item_bundle_discount_pct = item.properties._kefey_bundle_discount | plus: 0
                assign item_is_bundle = false
                if item.properties._kefey_bundle != blank and item_bundle_discount_pct > 0
                  assign item_is_bundle = true
                endif
                assign item_is_upsell = false
                if item.properties._kefey_upsell != blank
                  assign item_is_upsell = true
                endif

                if item_is_bundle
                  assign item_bundle_discount_amount = item.original_price | times: item_bundle_discount_pct | divided_by: 100
                  assign item_bundle_unit_final = item.original_price | minus: item_bundle_discount_amount
                  assign item_bundle_line_final = item_bundle_unit_final | times: item.quantity
                  assign kefey_display_total = kefey_display_total | plus: item_bundle_line_final
                elsif item_is_upsell
                  assign item_upsell_discount_amount = item.original_price | times: 10 | divided_by: 100
                  assign item_upsell_unit_final = item.original_price | minus: item_upsell_discount_amount
                  assign item_upsell_line_final = item_upsell_unit_final | times: item.quantity
                  assign kefey_display_total = kefey_display_total | plus: item_upsell_line_final
                elsif item.selling_plan_allocation != null
                  assign kefey_display_total = kefey_display_total | plus: item.final_line_price
                else
                  assign kefey_display_total = kefey_display_total | plus: item.original_line_price
                endif
              endfor
            endif
          -%}

          <div class="kefey-cart-upsell-row">
            <p class="kefey-cart-upsell-text">{{ section.settings.upsell_label }}</p>

            <div class="kefey-cart-upsell-actions">
              {%- if section.settings.upsell_button_label != blank -%}
                <button
                  type="button"
                  class="kefey-cart-upsell-button"
                  data-cart-offer-button
                  data-upsell-add
                  data-variant-id="{{ section.settings.upsell_variant_id | strip }}"
                  data-quantity="1"
                  data-discount-code="{{ section.settings.upsell_discount_code | strip }}"
                  data-fallback-url="{{ section.settings.upsell_button_link | default: '#' }}"
                >
                  {{ section.settings.upsell_button_label }}
                </button>
              {%- endif -%}
            </div>

            <p class="kefey-cart-upsell-total">TOTAL: {{ kefey_display_total | money }}</p>
          </div>
        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p
        class="visually-hidden"
        id="shopping-cart-line-item-status"
        aria-live="polite"
        aria-hidden="true"
        role="status"
      >
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </div>
</cart-items>

