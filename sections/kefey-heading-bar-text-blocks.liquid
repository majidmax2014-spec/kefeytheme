{{ 'kefey-heading-bar-text-blocks.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign h_ff = 'inherit'
  if section.settings.heading_font_family == 'heading'
    assign h_ff = 'var(--font-heading-family)'
  elsif section.settings.heading_font_family == 'body'
    assign h_ff = 'var(--font-body-family)'
  endif

  assign b_ff = 'inherit'
  if section.settings.body_font_family == 'heading'
    assign b_ff = 'var(--font-heading-family)'
  elsif section.settings.body_font_family == 'body'
    assign b_ff = 'var(--font-body-family)'
  endif

  assign b_style = 'normal'
  if section.settings.body_italic
    assign b_style = 'italic'
  endif

  assign bar_pad_em = section.settings.bar_extend | times: 0.01
-%}

<section
  id="KefeyHeadingBarTextBlocks-{{ section.id }}"
  class="khb"
  style="
    --khb-bg: {{ section.settings.section_background }};
    --khb-max: {{ section.settings.content_max_width }}px;
    --khb-px: {{ section.settings.padding_horizontal }}px;
    --khb-px-m: {{ section.settings.padding_horizontal_mobile }}px;
    --khb-pt: {{ section.settings.padding_top }}px;
    --khb-pb: {{ section.settings.padding_bottom }}px;
    --khb-pt-m: {{ section.settings.padding_top_mobile }}px;
    --khb-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --khb-gap-blocks: {{ section.settings.gap_between_blocks }}px;
    --khb-gap-blocks-m: {{ section.settings.gap_between_blocks_mobile }}px;
    --khb-gap-heading-body: {{ section.settings.gap_heading_to_body }}px;
    --khb-gap-heading-body-m: {{ section.settings.gap_heading_to_body_mobile }}px;
    --khb-body-mw: {{ section.settings.body_max_width }}px;
    --khb-h-ff: {{ h_ff }};
    --khb-h-fw: {{ section.settings.heading_font_weight }};
    --khb-h-fs: {{ section.settings.heading_font_size }}px;
    --khb-h-fs-m: {{ section.settings.heading_font_size_mobile }}px;
    --khb-h-lh: {{ section.settings.heading_line_height | times: 0.01 }};
    --khb-h-lh-m: {{ section.settings.heading_line_height_mobile | times: 0.01 }};
    --khb-h-track: {{ section.settings.heading_letter_spacing | times: 0.001 }}em;
    --khb-h-color: {{ section.settings.heading_color }};
    --khb-bar-h: {{ section.settings.bar_height }}px;
    --khb-bar-h-m: {{ section.settings.bar_height_mobile }}px;
    --khb-bar-b: {{ section.settings.bar_offset_bottom }}px;
    --khb-bar-b-m: {{ section.settings.bar_offset_bottom_mobile }}px;
    --khb-bar-pad: {{ bar_pad_em }}em;
    --khb-bar-radius: {{ section.settings.bar_border_radius }}px;
    --khb-b-ff: {{ b_ff }};
    --khb-b-fw: {{ section.settings.body_font_weight }};
    --khb-b-fs: {{ section.settings.body_font_size }}px;
    --khb-b-fs-m: {{ section.settings.body_font_size_mobile }}px;
    --khb-b-lh: {{ section.settings.body_line_height | times: 0.01 }};
    --khb-b-lh-m: {{ section.settings.body_line_height_mobile | times: 0.01 }};
    --khb-b-color: {{ section.settings.body_color }};
    --khb-b-style: {{ b_style }};
    --khb-b-p-gap: {{ section.settings.body_paragraph_gap }}px;
  "
>
  <div class="khb__shell">
    {% for block in section.blocks %}
      {% if block.type == 'panel' %}
        <div class="khb__block" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <div class="khb__title-wrap">
              <h2 class="khb__title">
                <span class="khb__title-text">{{ block.settings.heading }}</span>
                <span
                  class="khb__title-bar"
                  style="background-color: {{ block.settings.bar_color }};"
                  aria-hidden="true"
                ></span>
              </h2>
            </div>
          {% endif %}
          {% if block.settings.body != blank %}
            <div class="khb__body rte">{{ block.settings.body }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Heading bar + text blocks",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "section_background", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "content_max_width", "label": "Content max width", "min": 960, "max": 1400, "step": 8, "default": 1200 },
    { "type": "range", "id": "body_max_width", "label": "Body column max width", "min": 560, "max": 1000, "step": 10, "default": 820 },
    { "type": "range", "id": "padding_horizontal", "label": "Padding horizontal (desktop)", "min": 12, "max": 48, "step": 2, "default": 24 },
    { "type": "range", "id": "padding_horizontal_mobile", "label": "Padding horizontal (mobile)", "min": 12, "max": 28, "step": 2, "default": 18 },
    { "type": "range", "id": "padding_top", "label": "Padding top (desktop)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (desktop)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "min": 0, "max": 80, "step": 4, "default": 32 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "min": 0, "max": 80, "step": 4, "default": 40 },
    { "type": "range", "id": "gap_between_blocks", "label": "Space between panels (desktop)", "min": 24, "max": 96, "step": 4, "default": 48 },
    { "type": "range", "id": "gap_between_blocks_mobile", "label": "Space between panels (mobile)", "min": 16, "max": 72, "step": 4, "default": 36 },
    { "type": "range", "id": "gap_heading_to_body", "label": "Space: heading to body (desktop)", "min": 8, "max": 48, "step": 2, "default": 28 },
    { "type": "range", "id": "gap_heading_to_body_mobile", "label": "Space: heading to body (mobile)", "min": 8, "max": 40, "step": 2, "default": 20 },

    { "type": "header", "content": "Heading bar (default)" },
    { "type": "color", "id": "default_bar_color", "label": "Default bar color", "default": "#4db6ac" },
    { "type": "range", "id": "bar_height", "label": "Bar height (desktop)", "min": 6, "max": 24, "step": 1, "default": 12 },
    { "type": "range", "id": "bar_height_mobile", "label": "Bar height (mobile)", "min": 4, "max": 18, "step": 1, "default": 10 },
    { "type": "range", "id": "bar_offset_bottom", "label": "Bar vertical offset (desktop)", "min": -12, "max": 12, "step": 1, "default": -6 },
    { "type": "range", "id": "bar_offset_bottom_mobile", "label": "Bar vertical offset (mobile)", "min": -10, "max": 10, "step": 1, "default": -5 },
    { "type": "range", "id": "bar_extend", "label": "Bar horizontal extend (×0.01 em)", "min": 0, "max": 20, "step": 1, "default": 4 },
    { "type": "range", "id": "bar_border_radius", "label": "Bar corner radius", "min": 0, "max": 8, "step": 1, "default": 2 },

    { "type": "header", "content": "Heading typography" },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font family",
      "default": "heading",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    { "type": "range", "id": "heading_font_size", "label": "Heading size (desktop)", "min": 20, "max": 48, "step": 1, "default": 32 },
    { "type": "range", "id": "heading_font_size_mobile", "label": "Heading size (mobile)", "min": 18, "max": 36, "step": 1, "default": 22 },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height (%)", "min": 100, "max": 140, "step": 2, "default": 112 },
    { "type": "range", "id": "heading_line_height_mobile", "label": "Heading line height mobile (%)", "min": 100, "max": 140, "step": 2, "default": 112 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -40, "max": 120, "step": 2, "default": 0 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#101010" },

    { "type": "header", "content": "Body typography" },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Body font family",
      "default": "body",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Body font weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" }
      ]
    },
    { "type": "checkbox", "id": "body_italic", "label": "Italic body text", "default": false },
    { "type": "range", "id": "body_font_size", "label": "Body size (desktop)", "min": 12, "max": 24, "step": 1, "default": 17 },
    { "type": "range", "id": "body_font_size_mobile", "label": "Body size (mobile)", "min": 12, "max": 20, "step": 1, "default": 15 },
    { "type": "range", "id": "body_line_height", "label": "Body line height (%)", "min": 120, "max": 200, "step": 2, "default": 154 },
    { "type": "range", "id": "body_line_height_mobile", "label": "Body line height mobile (%)", "min": 120, "max": 200, "step": 2, "default": 150 },
    { "type": "range", "id": "body_paragraph_gap", "label": "Paragraph spacing", "min": 0, "max": 28, "step": 2, "default": 12 },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#101010" }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Perks of Being a Kefey Ambassador"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<ul><li>Be among the first to try new Kefey products.</li><li>Access exclusive previews, early drops, and limited releases.</li><li>Join a global community of wellness-driven creators.</li><li>Turn your passion for positivity and wellbeing into real revenue.</li></ul>"
        },
        {
          "type": "color",
          "id": "bar_color",
          "label": "Bar color",
          "default": "#4db6ac",
          "info": "Per panel. Match section default or pick another accent."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Heading bar + text blocks",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "heading": "Perks of Being a Kefey Ambassador",
            "body": "<ul><li>Be among the first to try new Kefey products.</li><li>Access exclusive previews, early drops, and limited releases.</li><li>Join a global community of wellness-driven creators.</li><li>Turn your passion for positivity and wellbeing into real revenue.</li></ul>"
          }
        },
        {
          "type": "panel",
          "settings": {
            "heading": "A Purpose-Driven, Eco-Friendly Brand",
            "body": "<p>At Kefey®, we believe in joyful wellness, eco-friendly choices, and meaningful impact.</p><p>As an ambassador, you represent a brand that cares about people, the planet, and building a positive global community.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
