{{ 'kefey-logo-text-marquee.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign text_ff = 'inherit'
  if section.settings.text_font_family == 'heading'
    assign text_ff = 'var(--font-heading-family)'
  elsif section.settings.text_font_family == 'body'
    assign text_ff = 'var(--font-body-family)'
  endif
-%}

<section
  id="KefeyLogoTextMarquee-{{ section.id }}"
  class="ktm"
  style="
    --ktm-bg: {{ section.settings.background_color }};
    --ktm-color: {{ section.settings.text_color }};
    --ktm-text-ff: {{ text_ff }};
    --ktm-text-fw: {{ section.settings.text_font_weight }};
    --ktm-text-size: {{ section.settings.text_size_desktop }}px;
    --ktm-text-size-m: {{ section.settings.text_size_mobile }}px;
    --ktm-gap: {{ section.settings.item_gap_desktop }}px;
    --ktm-gap-m: {{ section.settings.item_gap_mobile }}px;
    --ktm-sep-color: {{ section.settings.separator_color }};
    --ktm-sep-size: {{ section.settings.separator_size_desktop }}px;
    --ktm-sep-size-m: {{ section.settings.separator_size_mobile }}px;
    --ktm-logo-h: {{ section.settings.logo_height_desktop }}px;
    --ktm-logo-h-m: {{ section.settings.logo_height_mobile }}px;
    --ktm-bar-h: {{ section.settings.bar_height_desktop }}px;
    --ktm-bar-h-m: {{ section.settings.bar_height_mobile }}px;
    --ktm-speed: {{ section.settings.speed_seconds }}s;
    --ktm-pt: {{ section.settings.padding_top }}px;
    --ktm-pb: {{ section.settings.padding_bottom }}px;
    --ktm-pt-m: {{ section.settings.padding_top_mobile }}px;
    --ktm-pb-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="ktm__viewport">
    {%- capture items_markup -%}
      {%- for block in section.blocks -%}
        <span class="ktm__item" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            {{
              block.settings.logo
              | image_url: width: 260
              | image_tag:
                class: 'ktm__logo',
                loading: 'lazy',
                widths: '80, 120, 160, 220, 260',
                sizes: '(max-width: 749px) 72px, 92px',
                alt: block.settings.text
            }}
          {% endif %}
          {% if block.settings.text != blank %}
            <span class="ktm__text">{{ block.settings.text }}</span>
          {% endif %}
          <span class="ktm__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        </span>
      {%- endfor -%}
    {%- endcapture -%}

    <div class="ktm__track{% if section.settings.direction == 'right' %} ktm__track--right{% endif %}">
      <div class="ktm__group">{{ items_markup }}</div>
      <div class="ktm__group" aria-hidden="true">{{ items_markup }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kefey logo text marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background", "default": "#47b8bb" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    {
      "type": "select",
      "id": "text_font_family",
      "label": "Text font family",
      "default": "heading",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "text_font_weight",
      "label": "Text font weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    { "type": "range", "id": "text_size_desktop", "label": "Text size (desktop)", "min": 14, "max": 40, "step": 1, "default": 39 },
    { "type": "range", "id": "text_size_mobile", "label": "Text size (mobile)", "min": 12, "max": 30, "step": 1, "default": 17 },
    { "type": "range", "id": "logo_height_desktop", "label": "Logo height (desktop)", "min": 10, "max": 36, "step": 1, "default": 24 },
    { "type": "range", "id": "logo_height_mobile", "label": "Logo height (mobile)", "min": 8, "max": 30, "step": 1, "default": 14 },
    { "type": "range", "id": "bar_height_desktop", "label": "Bar height (desktop)", "min": 28, "max": 120, "step": 2, "default": 76 },
    { "type": "range", "id": "bar_height_mobile", "label": "Bar height (mobile)", "min": 24, "max": 80, "step": 2, "default": 48 },
    { "type": "range", "id": "item_gap_desktop", "label": "Gap between items (desktop)", "min": 8, "max": 80, "step": 2, "default": 24 },
    { "type": "range", "id": "item_gap_mobile", "label": "Gap between items (mobile)", "min": 6, "max": 56, "step": 2, "default": 12 },
    { "type": "text", "id": "separator", "label": "Separator", "default": "|" },
    { "type": "color", "id": "separator_color", "label": "Separator color", "default": "#ffffff" },
    { "type": "range", "id": "separator_size_desktop", "label": "Separator size (desktop)", "min": 14, "max": 52, "step": 1, "default": 42 },
    { "type": "range", "id": "separator_size_mobile", "label": "Separator size (mobile)", "min": 12, "max": 38, "step": 1, "default": 23 },
    { "type": "range", "id": "speed_seconds", "label": "Scroll speed (seconds)", "min": 8, "max": 60, "step": 1, "default": 24 },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "default": "left",
      "options": [
        { "value": "left", "label": "Right to left" },
        { "value": "right", "label": "Left to right" }
      ]
    },
    { "type": "range", "id": "padding_top", "label": "Padding top (desktop)", "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (desktop)", "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "min": 0, "max": 40, "step": 2, "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "min": 0, "max": 40, "step": 2, "default": 0 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo image" },
        { "type": "text", "id": "text", "label": "Text", "default": "+ Trees / forest - without people" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Kefey logo text marquee",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
