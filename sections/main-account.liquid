{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'kefey-customer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign subscription_url = section.settings.subscription_url | default: '/tools/recurring/login'
  assign subscription_label = section.settings.subscription_label | default: 'Manage subscriptions'
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account kefey-customer kefey-customer--account section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="kefey-customer__header">
      <div class="kefey-customer__title-wrap">
        <h1 class="kefey-customer__title">{{ section.settings.heading | default: 'My Account' }}</h1>
        <span class="kefey-customer__title-highlight" aria-hidden="true"></span>
      </div>
      <a href="{{ routes.account_logout_url }}" class="kefey-customer__logout">
        {{ 'customer.log_out' | t }}
      </a>
    </div>

    {% render 'kefey-customer-nav',
      subscription_url: subscription_url,
      subscription_label: subscription_label,
      active_page: 'orders'
    %}

    <div class="kefey-customer__grid kefey-customer__grid--account">
      {%- if section.settings.show_subscription_card and subscription_url != blank -%}
        <div class="kefey-customer__card kefey-customer__card--subscription">
          <h2>{{ section.settings.subscription_heading | default: 'Subscriptions' }}</h2>
          <p>{{ section.settings.subscription_text | default: 'Pause, skip, reschedule, or cancel your Mood Gummies subscription anytime.' }}</p>
          <a href="{{ subscription_url }}" class="kefey-customer__btn">{{ subscription_label }}</a>
        </div>
      {%- endif -%}

      <div class="kefey-customer__card kefey-customer__card--details">
        <h2>{{ 'customer.account.details' | t }}</h2>
        <div class="kefey-customer__address">
          {{ customer.default_address | format_address }}
        </div>
        <a href="{{ routes.account_addresses_url }}" class="kefey-customer__btn kefey-customer__btn--outline">
          {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
        </a>
      </div>

      <div class="kefey-customer__card kefey-customer__card--orders">
        <h2>{{ 'customer.orders.title' | t }}</h2>

        {% paginate customer.orders by 20 %}
          {%- if customer.orders.size > 0 -%}
            <table role="table" class="order-history">
              <caption class="visually-hidden">
                {{ 'customer.orders.title' | t }}
              </caption>
              <thead role="rowgroup">
                <tr role="row">
                  <th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
                  <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
                  <th id="ColumnPayment" scope="col" role="columnheader">{{ 'customer.orders.payment_status' | t }}</th>
                  <th id="ColumnFulfillment" scope="col" role="columnheader">
                    {{ 'customer.orders.fulfillment_status' | t }}
                  </th>
                  <th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th>
                </tr>
              </thead>
              <tbody role="rowgroup">
                {%- for order in customer.orders -%}
                  <tr role="row">
                    <td
                      id="RowOrder"
                      role="cell"
                      headers="ColumnOrder"
                      data-label="{{ 'customer.orders.order_number' | t }}"
                    >
                      <a
                        href="{{ order.customer_url }}"
                        aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                      >
                        {{ order.name }}
                      </a>
                    </td>
                    <td headers="RowOrder ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t }}">
                      {{ order.created_at | time_tag: format: 'date' }}
                    </td>
                    <td
                      headers="RowOrder ColumnPayment"
                      role="cell"
                      data-label="{{ 'customer.orders.payment_status' | t }}"
                    >
                      {{ order.financial_status_label }}
                    </td>
                    <td
                      headers="RowOrder ColumnFulfillment"
                      role="cell"
                      data-label="{{ 'customer.orders.fulfillment_status' | t }}"
                    >
                      {{ order.fulfillment_status_label }}
                    </td>
                    <td headers="RowOrder ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t }}">
                      {{ order.total_net_amount | money_with_currency }}
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- else -%}
            <p class="kefey-customer__empty">{{ 'customer.orders.none' | t }}</p>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
            {%- if paginate.parts.size > 0 -%}
              <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
                <ul role="list">
                  {%- if paginate.previous -%}
                    <li>
                      <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                        <span class="svg-wrapper">
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                        </span>
                      </a>
                    </li>
                  {%- endif -%}

                  {%- for part in paginate.parts -%}
                    <li>
                      {%- if part.is_link -%}
                        <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                          {{- part.title -}}
                        </a>
                      {%- else -%}
                        {%- if part.title == paginate.current_page -%}
                          <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                            {{- part.title -}}
                          </span>
                        {%- else -%}
                          <span>{{ part.title }}</span>
                        {%- endif -%}
                      {%- endif -%}
                    </li>
                  {%- endfor -%}

                  {%- if paginate.next -%}
                    <li>
                      <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                        <span class="svg-wrapper">
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                        </span>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </nav>
            {%- endif -%}
          {%- endif -%}
        {% endpaginate %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Account"
    },
    {
      "type": "header",
      "content": "Subscriptions"
    },
    {
      "type": "checkbox",
      "id": "show_subscription_card",
      "label": "Show subscription card",
      "default": true
    },
    {
      "type": "text",
      "id": "subscription_heading",
      "label": "Subscription card heading",
      "default": "Subscriptions"
    },
    {
      "type": "textarea",
      "id": "subscription_text",
      "label": "Subscription card text",
      "default": "Pause, skip, reschedule, or cancel your Mood Gummies subscription anytime."
    },
    {
      "type": "text",
      "id": "subscription_label",
      "label": "Subscription button label",
      "default": "Manage subscriptions"
    },
    {
      "type": "url",
      "id": "subscription_url",
      "label": "Subscription management URL",
      "info": "Use /tools/recurring/login for Recharge on classic accounts, or your Shopify account subscriptions page for Unity."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
