{%- liquid
  assign product_handle = section.settings.product_handle | default: 'mood-gummies' | strip | handleize
  assign target_url = section.settings.product_url
  assign redirect_product = all_products[product_handle]

  if target_url == blank and redirect_product != blank
    assign target_url = redirect_product.url
  endif

  if target_url == blank and product_handle != blank
    assign target_url = '/products/' | append: product_handle
  endif

  if target_url == blank and collections.all.products.first != blank
    assign target_url = collections.all.products.first.url
  endif
-%}

{%- if target_url != blank and request.design_mode == false -%}
  <meta http-equiv="refresh" content="0; url={{ target_url }}">
  <script>
    window.location.replace({{ target_url | json }});
  </script>
{%- endif -%}

<section class="page-width" style="padding: 60px 0; text-align: center;">
  {%- if target_url != blank -%}
    {%- if request.design_mode -%}
      <p>This page redirects visitors to <a href="{{ target_url }}">{{ target_url }}</a>. Redirect is disabled inside the theme editor.</p>
    {%- else -%}
      <p>Redirecting to product...</p>
      <p><a href="{{ target_url }}">Continue</a></p>
    {%- endif -%}
  {%- else -%}
    <p>Please set a product handle in this section.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Redirect to product",
  "class": "section-redirect-to-product",
  "settings": [
    { "type": "url", "id": "product_url", "label": "Single product URL" },
    { "type": "text", "id": "product_handle", "label": "Product handle", "default": "mood-gummies" }
  ],
  "presets": [{ "name": "Redirect to product" }]
}
{% endschema %}
