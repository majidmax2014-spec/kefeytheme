{{ 'thank-you-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign h_ff = 'inherit'
  if section.settings.heading_font_family == 'heading'
    assign h_ff = 'var(--font-heading-family)'
  elsif section.settings.heading_font_family == 'body'
    assign h_ff = 'var(--font-body-family)'
  endif

  assign b_ff = 'inherit'
  if section.settings.body_font_family == 'heading'
    assign b_ff = 'var(--font-heading-family)'
  elsif section.settings.body_font_family == 'body'
    assign b_ff = 'var(--font-body-family)'
  endif
-%}

<section
  id="ThankYouHero-{{ section.id }}"
  class="ty-hero"
  style="
    --ty-hero-teal: {{ section.settings.teal_color }};
    --ty-hero-max: {{ section.settings.max_width }}px;
    --ty-hero-pt: {{ section.settings.padding_top }}px;
    --ty-hero-pb: {{ section.settings.padding_bottom }}px;
    --ty-hero-pt-m: {{ section.settings.padding_top_mobile }}px;
    --ty-hero-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --ty-hero-heading-ff: {{ h_ff }};
    --ty-hero-body-ff: {{ b_ff }};
    --ty-hero-h1-fs: {{ section.settings.heading_1_size }}px;
    --ty-hero-h1-fw: {{ section.settings.heading_1_weight }};
    --ty-hero-h1-style: {{ section.settings.heading_1_style }};
    --ty-hero-sub-fs: {{ section.settings.subheading_size }}px;
    --ty-hero-sub-fw: {{ section.settings.subheading_weight }};
    --ty-hero-sub-style: {{ section.settings.subheading_style }};
    --ty-hero-h2-fs: {{ section.settings.heading_2_size }}px;
    --ty-hero-h2-fw: {{ section.settings.heading_2_weight }};
    --ty-hero-h2-style: {{ section.settings.heading_2_style }};
    --ty-hero-body-fs: {{ section.settings.body_size }}px;
    --ty-hero-body-fw: {{ section.settings.body_weight }};
    --ty-hero-body-style: {{ section.settings.body_style }};
    --ty-hero-order-fs: {{ section.settings.order_size }}px;
    --ty-hero-order-fw: {{ section.settings.order_weight }};
    --ty-hero-track-fs: {{ section.settings.track_size }}px;
    --ty-hero-track-fw: {{ section.settings.track_weight }};
    --ty-hero-track-border: {{ section.settings.track_border_width }}px;
  "
>
  <div class="ty-hero__inner">
    {% if section.settings.heading_1 != blank %}
      <h1 class="ty-hero__eyebrow">{{ section.settings.heading_1 }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="ty-hero__sub">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.heading_2 != blank %}
      <h2 class="ty-hero__title">{{ section.settings.heading_2 }}</h2>
    {% endif %}
    {% if section.settings.body != blank %}
      <div class="ty-hero__body rte">
        {{ section.settings.body }}
      </div>
    {% endif %}
    {% if section.settings.order_number_display != blank %}
      <p class="ty-hero__order">{{ section.settings.order_number_display }}</p>
    {% endif %}
    {% if section.settings.track_label != blank and section.settings.track_url != blank %}
      <a href="{{ section.settings.track_url }}" class="ty-hero__track">
        {{ section.settings.track_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Thank you hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading_1",
      "label": "Primary heading",
      "default": "Thank you for your purchase"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "High-Five for Joy!"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Secondary heading",
      "default": "Your order was successful"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Woohoo!</p><p>Your Kefey stars are packed with joy and on their way.</p><p>Get ready to unwrap a smile soon!</p>"
    },
    {
      "type": "text",
      "id": "order_number_display",
      "label": "Order line (static page)",
      "info": "Plain text placeholder; post-checkout order status uses Checkout.",
      "default": "ORDER #12345"
    },
    {
      "type": "text",
      "id": "track_label",
      "label": "Track button label",
      "default": "TRACK MY ORDER"
    },
    {
      "type": "url",
      "id": "track_url",
      "label": "Track button link",
      "info": "e.g. /account or your tracking URL."
    },
    {
      "type": "color",
      "id": "teal_color",
      "label": "Primary heading color",
      "default": "#4DB6AC"
    },
    {
      "type": "header",
      "content": "Typography — primary heading"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Font family (headings)",
      "default": "heading",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "range",
      "id": "heading_1_size",
      "label": "Size (px)",
      "min": 20,
      "max": 48,
      "step": 1,
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_1_weight",
      "label": "Weight",
      "default": "500",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "select",
      "id": "heading_1_style",
      "label": "Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "header",
      "content": "Typography — subheading"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" }
      ]
    },
    {
      "type": "select",
