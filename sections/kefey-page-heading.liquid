{{ 'kefey-page-sections.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign h_ff = 'inherit'
  if section.settings.font_family == 'heading'
    assign h_ff = 'var(--font-heading-family)'
  elsif section.settings.font_family == 'body'
    assign h_ff = 'var(--font-body-family)'
  endif

  assign align_class = 'kph__wrap--center'
  if section.settings.text_alignment == 'left'
    assign align_class = 'kph__wrap--left'
  elsif section.settings.text_alignment == 'right'
    assign align_class = 'kph__wrap--right'
  endif
-%}

<section
  id="KefeyPageHeading-{{ section.id }}"
  class="kph"
  style="
    background-color: {{ section.settings.background_color }};
    --kps-max: {{ section.settings.max_width }}px;
    --kps-content-mw: {{ section.settings.content_max_width_pct }}%;
    --kph-pt: {{ section.settings.padding_top }}px;
    --kph-pb: {{ section.settings.padding_bottom }}px;
    --kph-pt-m: {{ section.settings.padding_top_mobile }}px;
    --kph-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --kph-ff: {{ h_ff }};
    --kph-fw: {{ section.settings.font_weight }};
    --kph-fs: {{ section.settings.heading_size }}px;
    --kph-color: {{ section.settings.heading_color }};
  "
>
  <div class="kps-shell">
    <div class="kps-column">
      <div class="kph__wrap {{ align_class }}">
        {% if section.settings.heading != blank %}
          <h2 class="kph__title">
            <span class="kph__title-text">{{ section.settings.heading | escape }}</span>
            <span
              class="kph__title-highlight"
              style="background-color: {{ section.settings.highlight_color }};"
              aria-hidden="true"
            ></span>
          </h2>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kefey page heading",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your heading here"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight (underline) color",
      "default": "#4DB6AC",
      "info": "Teal bar behind the lower part of the text — same style as Testimonials."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text color",
      "default": "#101010"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font",
      "default": "heading",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "default": "700",
      "options": [
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (px)",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 28
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Outer max width (px)",
      "min": 600,
      "max": 1400,
      "step": 10,
      "default": 1200
    },
    {
      "type": "range",
      "id": "content_max_width_pct",
      "label": "Text column width",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 66,
      "info": "Relative to the outer container. Full width of column on small screens."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Kefey page heading"
    }
  ]
}
{% endschema %}
