{{ 'we-refuse-section.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign wrs_h_ff = 'inherit'
  if section.settings.heading_font_family == 'heading'
    assign wrs_h_ff = 'var(--font-heading-family)'
  elsif section.settings.heading_font_family == 'body'
    assign wrs_h_ff = 'var(--font-body-family)'
  endif

  assign wrs_t_ff = 'inherit'
  if section.settings.text_font_family == 'heading'
    assign wrs_t_ff = 'var(--font-heading-family)'
  elsif section.settings.text_font_family == 'body'
    assign wrs_t_ff = 'var(--font-body-family)'
  endif
-%}

<section
  id="WeRefuseSection-{{ section.id }}"
  class="we-refuse-section"
  style="
    --wrs-bg: {{ section.settings.section_bg }};
    --wrs-title-bg: {{ section.settings.title_bg }};
    --wrs-title-color: {{ section.settings.title_color }};
    --wrs-right-bg: {{ section.settings.right_bg }};
    --wrs-text-color: {{ section.settings.text_color }};
    --wrs-max: {{ section.settings.content_max_width }}px;
    --wrs-left: {{ section.settings.left_col_width }}%;
    --wrs-pt: {{ section.settings.padding_top }}px;
    --wrs-pb: {{ section.settings.padding_bottom }}px;
    --wrs-left-pt: {{ section.settings.left_text_padding_top }}px;
    --wrs-left-pt-m: {{ section.settings.left_text_padding_top_mobile }}px;
    --wrs-h-ff: {{ wrs_h_ff }};
    --wrs-h-fw: {{ section.settings.heading_font_weight }};
    --wrs-h-fs: {{ section.settings.heading_font_size }}px;
    --wrs-t-ff: {{ wrs_t_ff }};
    --wrs-t-fw: {{ section.settings.text_font_weight }};
    --wrs-t-fs: {{ section.settings.text_font_size }}px;
    --wrs-btn-bg: {{ section.settings.button_background }};
    --wrs-btn-color: {{ section.settings.button_text_color }};
    --wrs-btn-fs: {{ section.settings.button_font_size }}px;
    --wrs-btn-pad-y: {{ section.settings.button_padding_y }}px;
    --wrs-btn-pad-x: {{ section.settings.button_padding_x }}px;
    --wrs-btn-mt: {{ section.settings.button_margin_top }}px;
    --wrs-btn-mt-m: {{ section.settings.button_margin_top_mobile }}px;
  "
>
  <div class="we-refuse-section__inner">
    <div class="we-refuse-section__titlebar">
      <h2 class="we-refuse-section__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="we-refuse-section__grid">
      <div class="we-refuse-section__left">
        {% if section.settings.text != blank %}
          <div class="we-refuse-section__text rte">{{ section.settings.text }}</div>
        {% endif %}

        {% if section.settings.show_button and section.settings.button_label != blank %}
          <div class="we-refuse-section__btn-wrap">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="we-refuse-section__btn"
            >
              <span class="we-refuse-section__btn-label">{{ section.settings.button_label }}</span>
              {% if section.settings.button_show_arrow %}
                <span class="we-refuse-section__btn-arrow" aria-hidden="true">→</span>
              {% endif %}
            </a>
          </div>
        {% endif %}
      </div>

      <div class="we-refuse-section__right">
        {% if section.settings.right_image != blank %}
          {{
            section.settings.right_image
            | image_url: width: 1600
            | image_tag:
              class: 'we-refuse-section__image',
              loading: 'lazy',
              widths: '360, 560, 760, 960, 1200, 1600',
              sizes: '(max-width: 989px) 100vw, 58vw',
              alt: section.settings.right_image.alt
          }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "We Refuse Section",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "We refuse to be part of that." },
    {
      "type": "richtext",
      "id": "text",
      "label": "Left text",
      "default": "<ul><li>Kefey\u00ae signature tube is crafted from premium, non-plastic materials, designed to stay - not to be used once and forgotten.</li><li>On your desk, on your shelf, as part of your daily space.</li><li>By focusing on highly concentrated formulas, fewer products are needed.</li><li>By choosing non-plastic, reusable packaging, waste is reduced by design.</li><li>Because caring for yourself should not have to come at the planet's expense.</li></ul>"
    },
    { "type": "image_picker", "id": "right_image", "label": "Right image" },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#efefef" },
    { "type": "color", "id": "title_bg", "label": "Title bar background", "default": "#e95439" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#ffffff" },
    { "type": "color", "id": "right_bg", "label": "Right panel background", "default": "#69c6de" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1e1e1e" },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "inherit" },
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    { "type": "range", "id": "heading_font_size", "label": "Heading font size", "min": 16, "max": 96, "step": 2, "default": 42 },
    {
      "type": "select",
      "id": "text_font_family",
      "label": "Body font family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "select",
      "id": "text_font_weight",
      "label": "Body font weight",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "inherit" },
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ]
    },
    { "type": "range", "id": "text_font_size", "label": "Body font size", "min": 10, "max": 32, "step": 1, "default": 18 },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_show_arrow",
      "label": "Show arrow after label",
      "default": true
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#49b2b2"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 11,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "label": "Button padding vertical",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Button padding horizontal",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "label": "Space above button (desktop)",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_margin_top_mobile",
      "label": "Space above button (mobile)",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    { "type": "range", "id": "content_max_width", "label": "Content max width", "min": 980, "max": 1700, "step": 10, "default": 1220 },
    { "type": "range", "id": "left_col_width", "label": "Left column width (%)", "min": 30, "max": 60, "step": 1, "default": 42 },
    {
      "type": "range",
      "id": "left_text_padding_top",
      "label": "Left text offset from top (desktop)",
      "min": 60,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 120,
      "info": "Space above the left text block. Increase if the title bar overlaps your copy."
    },
    {
      "type": "range",
      "id": "left_text_padding_top_mobile",
      "label": "Left text offset from top (mobile)",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 220, "step": 4, "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 220, "step": 4, "default": 40 }
  ],
  "presets": [{ "name": "We Refuse Section" }]
}
{% endschema %}
