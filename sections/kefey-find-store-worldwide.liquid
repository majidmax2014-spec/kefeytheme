{{ 'kefey-find-store.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign h_ff = 'inherit'
  if section.settings.heading_font_family == 'heading'
    assign h_ff = 'var(--font-heading-family)'
  elsif section.settings.heading_font_family == 'body'
    assign h_ff = 'var(--font-body-family)'
  endif

  assign b_ff = 'inherit'
  if section.settings.body_font_family == 'heading'
    assign b_ff = 'var(--font-heading-family)'
  elsif section.settings.body_font_family == 'body'
    assign b_ff = 'var(--font-body-family)'
  endif
-%}

<section
  id="FindStoreWorldwide-{{ section.id }}"
  class="fs-worldwide"
  style="
    --fs-ww-bg: {{ section.settings.background_color }};
    --fs-ww-radius: {{ section.settings.corner_radius }}px;
    --fs-ww-max: {{ section.settings.max_width }}px;
    --fs-ww-pt: {{ section.settings.padding_top }}px;
    --fs-ww-pb: {{ section.settings.padding_bottom }}px;
    --fs-ww-heading-ff: {{ h_ff }};
    --fs-ww-heading-fs: {{ section.settings.heading_size }}px;
    --fs-ww-body-ff: {{ b_ff }};
  "
>
  <div class="fs-worldwide__inner">
    {% if section.settings.decor_image != blank and section.settings.show_decor %}
      <div class="fs-worldwide__decor" aria-hidden="true">
        {{
          section.settings.decor_image
          | image_url: width: 480
          | image_tag: loading: 'lazy', alt: '', width: section.settings.decor_image.width, height: section.settings.decor_image.height
        }}
      </div>
    {% endif %}

    <div class="fs-worldwide__content">
      {% if section.settings.heading != blank %}
        <h2 class="fs-worldwide__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.body != blank %}
        <div class="fs-worldwide__body rte">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Find store worldwide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worldwide"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Kefey is growing globally. Check back for new retail partners in your region.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#EF6344"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius (px)",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_decor",
      "label": "Show decorative image",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "decor_image",
      "label": "Decorative image"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font",
      "default": "heading",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (px)",
      "min": 20,
      "max": 48,
      "step": 1,
      "default": 28
    },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Body font",
      "default": "body",
      "options": [
        { "value": "heading", "label": "Heading font" },
        { "value": "body", "label": "Body font" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Inner max width (px)",
      "min": 800,
      "max": 1400,
      "step": 10,
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Find store worldwide"
    }
  ]
}
{% endschema %}
