        "faq_what_is": {
          "type": "faq",
          "settings": {
            "question": "What are Kefey® Mood Gummies?",
            "answer": "<p>Kefey® Mood Gummies are plant-based supplements crafted with a concentrated blend of seven herbal extracts (Ashwagandha Root Extract, Gotu Kola Extract, Maca Root Extract, Vervain Extract, Moringa Leaf Extract, Milk Thistle Extract, Korean Red Ginseng Extract) and Zinc Citrate.<br/></p><p>They’re designed to support daily balance, focus, and vitality — delivered in a joyful, star-shaped gummy you’ll actually enjoy taking, everyday.<br/><br/><br/><br/></p>"
          }
        },
        "faq_how_many": {
          "type": "faq",
          "settings": {
            "question": "How many gummies should I take per day?",
            "answer": "<p>Take 2 gummies twice daily, preferably with a meal. </p><p>Each serving (2 stars) delivers a concentrated herbal blend equivalent to over <strong>11,000 mg of dried botanicals</strong>.</p>"
          }
        },
        "faq_with_food": {
          "type": "faq",
          "settings": {
            "question": "Do I need to take them with food?",
            "answer": "<p>You can take Kefey® Mood Gummies <strong>with or without food</strong>. For best absorption and comfort, we recommend taking them <strong>after a light meal</strong>.</p>"
          }
        },
        "faq_vegan": {
          "type": "faq",
          "settings": {
            "question": "Are Kefey® Mood Gummies vegan?",
            "answer": "<p>✅ Yes. Kefey® Mood Gummies are 100% vegan friendly and vegetarian.</p><p>They’re made with fruit-derived pectin instead of gelatin — never animal-based ingredients, making them both vegan and vegetarian.</p>"
          }
        },
